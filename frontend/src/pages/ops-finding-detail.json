{
  "id": "ops-finding-detail",
  "title": "Ops Finding Detail",
  "state": {
    "accessToken": "",
    "approveNote": "",
    "rejectReason": "",
    "findingStatusOverride": null,
    "isSubmitting": false,
    "actionError": null,
    "queueSource": "",
    "queueSeverityFilter": "%",
    "queueStatusFilter": "%",
    "queueBranchFilter": "%",
    "queueCustomerFilter": "%",
    "queueContractLabel": "",
    "queueCustomerName": "",
    "queueDelta": null,
    "returnSeverity": "%",
    "returnStatus": "%",
    "returnBranch": "%",
    "returnCustomer": "%",
    "returnSignal": "%",
    "returnPriority": "%",
    "returnObligation": "%"
  },
  "dataSources": {
    "finding": {
      "type": "supabase",
      "table": "ops_findings_view",
      "select": "id, agent_key, run_id, workflow_id, contract_id, contract_label, line_item_id, line_item_label, customer_name, finding_type, severity, status, expected, expected_amount, billed, billed_amount, delta, evidence, proposed_action, confidence, rationale, created_at",
      "filters": [
        { "field": "id", "op": "eq", "value": "{{params.findingId}}" }
      ],
      "single": true,
      "refetchInterval": 10000
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Link",
        "if": "{{state.queueSource === 'revenue-recognition'}}",
        "props": {
          "to": "/ops/revenue-recognition",
          "search": {
            "severity": "{{state.returnSeverity}}",
            "status": "{{state.returnStatus}}",
            "branch": "{{state.returnBranch}}",
            "customer": "{{state.returnCustomer}}"
          },
          "children": "← Back to Revenue Recognition"
        }
      },
      {
        "type": "Link",
        "if": "{{state.queueSource === 'collections'}}",
        "props": {
          "to": "/ops/collections",
          "search": {
            "severity": "{{state.returnSeverity}}",
            "status": "{{state.returnStatus}}"
          },
          "children": "← Back to AR Collections"
        }
      },
      {
        "type": "Link",
        "if": "{{state.queueSource === 'account-health-queue'}}",
        "props": {
          "to": "/ops/account-health-queue",
          "search": {
            "signal": "{{state.returnSignal}}",
            "priority": "{{state.returnPriority}}",
            "status": "{{state.returnStatus}}",
            "customer": "{{state.returnCustomer}}"
          },
          "children": "← Back to Account Health Queue"
        }
      },
      {
        "type": "Link",
        "if": "{{state.queueSource === 'shop-morning-queue'}}",
        "props": {
          "to": "/ops/shop-morning-queue",
          "search": {
            "priority": "{{state.returnPriority}}",
            "status": "{{state.returnStatus}}"
          },
          "children": "← Back to Shop Morning Queue"
        }
      },
      {
        "type": "Link",
        "if": "{{state.queueSource === 'technician-morning-queue'}}",
        "props": {
          "to": "/ops/technician-morning-queue",
          "search": {
            "priority": "{{state.returnPriority}}",
            "status": "{{state.returnStatus}}"
          },
          "children": "← Back to Technician Morning Queue"
        }
      },
      {
        "type": "Link",
        "if": "{{state.queueSource === 'incident-compliance-queue'}}",
        "props": {
          "to": "/ops/incident-compliance-queue",
          "search": {
            "obligation": "{{state.returnObligation}}",
            "status": "{{state.returnStatus}}"
          },
          "children": "← Back to Incident Compliance Queue"
        }
      },
      {
        "type": "Link",
        "if": "{{state.queueSource !== 'revenue-recognition' && state.queueSource !== 'collections' && state.queueSource !== 'account-health-queue' && state.queueSource !== 'incident-compliance-queue' && state.queueSource !== 'shop-morning-queue' && state.queueSource !== 'technician-morning-queue'}}",
        "props": {
          "to": "/ops/fleet-audits",
          "search": {
            "severity": "{{state.returnSeverity}}",
            "status": "{{state.returnStatus}}",
            "branch": "{{state.returnBranch}}",
            "customer": "{{state.returnCustomer}}"
          },
          "children": "← Back to Fleet Audits"
        }
      },
      {
        "type": "Text",
        "if": "{{isLoading.finding}}",
        "props": {
          "variant": "default",
          "children": "Loading finding detail..."
        }
      },
      {
        "type": "Alert",
        "if": "{{errors.finding}}",
        "props": {
          "variant": "destructive",
          "title": "Unable to load finding",
          "description": "Try again shortly."
        }
      },
      {
        "type": "Alert",
        "if": "{{!auth.canOperate}}",
        "props": {
          "variant": "info",
          "title": "Read-only",
          "description": "You can review this finding, but only operators can approve or reject."
        }
      },
      {
        "type": "Stack",
        "if": "{{!errors.finding && data.finding}}",
        "props": { "spacing": 6 },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 3 },
            "children": [
              {
                "type": "Stack",
                "props": { "spacing": 2 },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "level": 1,
                      "children": "{{formatFindingType(data.finding.finding_type)}}"
                    }
                  },
                  {
                    "type": "Stack",
                    "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                    "children": [
                      {
                        "type": "Badge",
                        "props": {
                          "status": "{{data.finding.severity}}",
                          "children": "{{data.finding.severity}}"
                        }
                      },
                      {
                        "type": "Badge",
                        "props": {
                          "status": "{{state.findingStatusOverride || data.finding.status}}",
                          "children": "{{formatFindingStatus(state.findingStatusOverride || data.finding.status)}}"
                        }
                      },
                      {
                        "type": "Badge",
                        "if": "{{!auth.canOperate}}",
                        "props": {
                          "status": "read_only",
                          "children": "Read-only"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "variant": "muted",
                      "children": "{{data.finding.severity}} · {{formatFindingStatus(state.findingStatusOverride || data.finding.status)}}"
                    }
                  }
                ]
              },
              {
                "type": "Stack",
                "props": { "direction": "horizontal", "spacing": 6, "align": "end" },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "level": 2,
                      "size": "4xl",
                      "className": "tabular-nums {{data.finding.severity === 'critical' || data.finding.severity === 'high' ? 'text-red-600' : data.finding.severity === 'medium' ? 'text-amber-600' : 'text-green-700'}}",
                      "children": "Impact: {{formatCurrency(data.finding.delta !== null && data.finding.delta !== undefined ? data.finding.delta : state.queueDelta !== null && state.queueDelta !== undefined ? state.queueDelta : 0)}}"
                    }
                  },
                  {
                    "type": "Stack",
                    "props": { "spacing": 1 },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "Confidence"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-2xl font-semibold tabular-nums",
                          "children": "{{formatPercent(data.finding.confidence || 0)}} confident"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Stack",
            "props": {
              "spacing": 2,
              "className": "rounded-md border-l-4 border-l-primary bg-primary/5 p-4"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "weight": "semibold",
                  "children": "Proposed action"
                }
              },
              {
                "type": "Text",
                "props": {
                  "children": "{{data.finding.proposed_action || 'No proposed action provided.'}}"
                }
              }
            ]
          },
          {
            "type": "Stack",
            "props": { "spacing": 3 },
            "children": [
              {
                "type": "Grid",
                "props": { "columns": "repeat(auto-fit, minmax(16rem, 1fr))", "gap": 4 },
                "children": [
                  {
                    "type": "Card",
                    "props": { "title": "{{data.finding.agent_key === 'credit-analyst' ? 'Overdue AR' : 'Expected'}}" },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-xl font-semibold tabular-nums",
                          "children": "{{formatCurrency(data.finding.expected_amount || 0)}}"
                        }
                      },
                      {
                        "type": "Text",
                        "if": "{{data.finding.expected && data.finding.expected.rate_type}}",
                        "props": {
                          "variant": "muted",
                          "size": "sm",
                          "children": "{{data.finding.expected.rate_type}}"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Card",
                    "props": { "title": "{{data.finding.agent_key === 'credit-analyst' ? 'Current exposure' : 'Billed'}}" },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-xl font-semibold tabular-nums",
                          "children": "{{formatCurrency(data.finding.billed_amount || 0)}}"
                        }
                      },
                      {
                        "type": "Text",
                        "if": "{{data.finding.billed && data.finding.billed.rate_type}}",
                        "props": {
                          "variant": "muted",
                          "size": "sm",
                          "children": "{{data.finding.billed.rate_type}}"
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Text",
                "props": {
                  "size": "sm",
                  "className": "font-medium tabular-nums {{data.finding.agent_key === 'credit-analyst' ? 'text-amber-700' : ((data.finding.billed_amount || 0) > (data.finding.expected_amount || 0) ? 'text-red-600' : 'text-green-700')}}",
                  "children": "{{data.finding.agent_key === 'credit-analyst' ? ('Overdue AR ' + formatCurrency(data.finding.expected_amount || 0) + ' · Current exposure ' + formatCurrency(data.finding.billed_amount || 0) + ' · Recommended path ' + (data.finding.proposed_action || 'manual review')) : ('Billed ' + formatCurrency(data.finding.billed_amount || 0) + ' − Expected ' + formatCurrency(data.finding.expected_amount || 0) + ' = ' + formatCurrency(data.finding.delta || 0) + ' ' + ((data.finding.billed_amount || 0) > (data.finding.expected_amount || 0) ? 'over-billed' : 'under-billed'))}}"
                }
              }
            ]
          },
          {
            "type": "Card",
            "props": { "title": "Evidence checklist" },
            "children": [
              {
                "type": "Text",
                "if": "{{!data.finding.evidence || data.finding.evidence.length === 0}}",
                "props": {
                  "variant": "muted",
                  "children": "No evidence supplied."
                }
              },
              {
                "type": "Stack",
                "if": "{{data.finding.evidence && data.finding.evidence.length > 0}}",
                "props": { "spacing": 2 },
                "children": [
                  {
                    "type": "Stack",
                    "each": "{{data.finding.evidence}}",
                    "as": "evidence",
                    "key": "{{index}}",
                    "props": { "direction": "horizontal", "justify": "between", "align": "center", "className": "rounded border p-2" },
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "size": "sm",
                              "className": "text-green-600",
                              "children": "✓"
                            }
                          },
                          {
                            "type": "Text",
                            "props": {
                              "size": "sm",
                              "children": "{{evidence.label || evidence.summary || evidence.description || evidence.event_type || evidence.type || 'Evidence item ' + (index + 1)}}"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Link",
                        "if": "{{data.finding.contract_id}}",
                        "props": {
                          "to": "/ops/audit/{{evidence.entity_id || data.finding.contract_id}}",
                          "children": "Audit"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Card",
            "props": { "title": "Rationale & confidence" },
            "children": [
              {
                "type": "Stack",
                "props": { "spacing": 3 },
                "children": [
                  {
                    "type": "Stack",
                    "props": {
                      "spacing": 0,
                      "className": "border-l-4 border-l-muted pl-4"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "italic text-muted-foreground",
                          "children": "{{data.finding.rationale || 'No rationale available.'}}"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "variant": "muted",
                      "children": "{{formatPercent(data.finding.confidence || 0)}} confident · Workflow: {{formatOpsAgentLabel(data.finding.agent_key)}}"
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "Card",
            "props": { "title": "Entity links" },
            "children": [
              {
                "type": "Stack",
                "props": { "spacing": 2 },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "children": "{{data.finding.agent_key === 'credit-analyst' ? 'Account' : 'Contract'}}: {{data.finding.contract_label || data.finding.expected.account_label || state.queueContractLabel || 'N/A'}}"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "children": "Line: {{data.finding.line_item_label || 'N/A'}}"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "children": "Customer: {{data.finding.customer_name || data.finding.expected.customer_name || state.queueCustomerName || 'N/A'}}"
                    }
                  },
                  {
                    "type": "Text",
                    "if": "{{data.finding.agent_key === 'credit-analyst'}}",
                    "props": {
                     "children": "Branch context: {{data.finding.expected.branch_context || 'N/A'}}"
                    }
                  },
                  {
                    "type": "Text",
                    "if": "{{data.finding.agent_key === 'credit-analyst'}}",
                    "props": {
                      "size": "sm",
                      "children": "Escalation: {{formatEscalationStage(data.finding.expected.escalation_stage)}}"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "variant": "muted",
                      "children": "Detected: {{formatDateTime(data.finding.created_at)}}"
                    }
                  },
                  {
                    "type": "Link",
                    "if": "{{data.finding.contract_id}}",
                    "props": {
                      "to": "/ops/audit/{{data.finding.contract_id}}",
                      "children": "Open audit trail"
                    }
                  },
                  {
                    "type": "Link",
                    "if": "{{state.queueSource === 'revenue-recognition'}}",
                    "props": {
                      "to": "/ops/revenue-recognition",
                      "search": {
                        "severity": "{{state.queueSeverityFilter || '%'}}",
                        "status": "{{state.queueStatusFilter || '%'}}",
                        "branch": "{{state.queueBranchFilter || '%'}}",
                        "customer": "{{state.queueCustomerFilter || '%'}}"
                      },
                      "children": "Back to filtered revenue queue"
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "Alert",
            "if": "{{state.actionError}}",
            "props": {
              "variant": "destructive",
              "title": "Action failed",
              "description": "{{state.actionError}}"
            }
          },
          {
            "type": "Alert",
            "if": "{{state.findingStatusOverride === 'approved' || state.findingStatusOverride === null && data.finding.status === 'approved'}}",
            "props": {
              "variant": "info",
              "title": "Finding approved",
              "description": "This finding has been approved. The workflow will proceed with the proposed action."
            }
          },
          {
            "type": "Alert",
            "if": "{{state.findingStatusOverride === 'rejected' || state.findingStatusOverride === null && data.finding.status === 'rejected'}}",
            "props": {
              "variant": "info",
              "title": "Finding rejected",
              "description": "This finding has been rejected. No further action will be taken."
            }
          },
          {
            "type": "Card",
            "if": "{{auth.canOperate ? state.findingStatusOverride === 'pending_approval' || state.findingStatusOverride === null && data.finding.status === 'pending_approval' : false}}",
            "props": { "title": "Approve / Reject" },
            "children": [
              {
                "type": "Stack",
                "props": { "spacing": 3 },
                "children": [
                  {
                    "type": "Textarea",
                    "props": {
                      "label": "Approval note (optional)",
                      "value": "{{state.approveNote}}",
                      "onChange": {
                        "action": "setState",
                        "key": "approveNote",
                        "value": "{{event.target.value}}"
                      }
                    }
                  },
                  {
                    "type": "Button",
                    "props": {
                      "children": "Approve",
                      "disabled": "{{state.isSubmitting}}",
                      "onClick": {
                        "action": "custom",
                        "handler": "opsApproveFinding",
                        "payload": {
                          "findingId": "{{params.findingId}}",
                          "note": "{{state.approveNote}}"
                        }
                      }
                    }
                  },
                  {
                    "type": "Textarea",
                    "props": {
                      "label": "Reject reason",
                      "value": "{{state.rejectReason}}",
                      "onChange": {
                        "action": "setState",
                        "key": "rejectReason",
                        "value": "{{event.target.value}}"
                      }
                    }
                  },
                  {
                    "type": "Button",
                    "props": {
                      "variant": "destructive",
                      "children": "Reject",
                      "disabled": "{{!state.rejectReason || state.isSubmitting}}",
                      "onClick": {
                        "action": "custom",
                        "handler": "opsRejectFinding",
                        "payload": {
                          "findingId": "{{params.findingId}}",
                          "reason": "{{state.rejectReason}}"
                        }
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "Alert",
            "if": "{{data.finding.status === 'informational'}}",
            "props": {
              "variant": "info",
              "title": "No action required",
              "description": "This finding is informational only."
            }
          }
        ]
      }
    ]
  }
}
