{
  "id": "rental-contract-detail",
  "title": "Rental Contract",
  "state": {
    "checkout_line_id": "",
    "checkout_asset_id": "",
    "checkout_actual_start": "",
    "checkout_line_status": "",
    "checkout_planned_end": "",
    "return_line_id": "",
    "return_actual_end": "",
    "return_asset_id": "",
    "return_line_status": "",
    "return_checked_out_date": ""
  },
  "dataSources": {
    "contract": {
      "type": "supabase",
      "table": "entities",
      "select": "*, entity_versions(*)",
      "filters": [
        { "field": "id", "op": "eq", "value": "{{params.id}}" }
      ],
      "single": true
    },
    "lines": {
      "type": "supabase",
      "table": "v_rental_contract_line_current",
      "select": "entity_id, version_id, version_number, status, contract_id, asset_id, category_id, rental_type, rate_type, rate_amount, actual_start, actual_end, data",
      "filters": [
        { "field": "contract_id", "op": "eq", "value": "{{params.id}}" }
      ],
      "order": [{ "column": "actual_start", "ascending": true }]
    },
    "contractInvoices": {
      "type": "supabase",
      "table": "entities",
      "select": "id, created_at, entity_versions!inner(data, is_current)",
      "filters": [
        { "field": "entity_type", "op": "eq", "value": "invoice" },
        { "field": "entity_versions.is_current", "op": "eq", "value": true },
        { "field": "entity_versions.data->>contract_id", "op": "eq", "value": "{{params.id}}" }
      ],
      "order": [{ "column": "created_at", "ascending": false }],
      "limit": 1
    },
    "contractInvoiceRelationships": {
      "type": "supabase",
      "table": "relationships_v2",
      "select": "parent_id, created_at",
      "filters": [
        { "field": "relationship_type", "op": "eq", "value": "invoice:generated_from:contract" },
        { "field": "is_current", "op": "eq", "value": true },
        { "field": "child_id", "op": "eq", "value": "{{params.id}}" }
      ],
      "order": [{ "column": "created_at", "ascending": false }],
      "limit": 1
    },
    "customers": {
      "type": "supabase",
      "table": "crm_customer_profile_current",
      "select": "entity_id, name",
      "order": [{ "column": "name", "ascending": true }]
    },
    "orders": {
      "type": "supabase",
      "table": "entities",
      "select": "id, entity_versions!inner(data, is_current)",
      "filters": [
        { "field": "entity_type", "op": "eq", "value": "rental_order" },
        { "field": "entity_versions.is_current", "op": "eq", "value": true }
      ],
      "order": [{ "column": "created_at", "ascending": false }]
    },
    "job_sites": {
      "type": "supabase",
      "table": "entities",
      "select": "id, source_record_id, entity_versions!inner(data, is_current)",
      "filters": [
        { "field": "entity_type", "op": "eq", "value": "job_site" },
        { "field": "entity_versions.is_current", "op": "eq", "value": true }
      ],
      "order": [{ "column": "source_record_id", "ascending": true }]
    },
    "asset_categories": {
      "type": "supabase",
      "table": "rental_asset_availability_current",
      "select": "asset_category_id, asset_category_name",
      "order": [{ "column": "asset_category_name", "ascending": true }]
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "direction": "horizontal", "justify": "between", "align": "start" },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 2 },
            "children": [
              {
                "type": "Link",
                "props": {
                  "to": "/rental/contracts",
                  "children": "← Back to Contracts"
                }
              },
              {
                "type": "Heading",
                "props": {
                  "level": 1,
                  "children": "{{data.contract.entity_versions[0].data.contract_number || 'Rental Contract'}}"
                }
              },
              {
                "type": "Stack",
                "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                "children": [
                  {
                    "type": "Badge",
                    "props": {
                      "variant": "secondary",
                      "children": "{{data.contract.entity_versions[0].data.status || 'pending_execution'}}"
                    }
                  },
                  {
                    "type": "Badge",
                    "props": {
                      "variant": "outline",
                      "children": "{{data.contract.entity_versions[0].data.rental_type || 'external'}}"
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Card",
        "props": { "title": "Contract Lifecycle" },
        "children": [
          {
            "type": "Stack",
            "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
            "children": [
              {
                "type": "Badge",
                "props": {
                  "variant": "{{data.contract.entity_versions[0].data.status === 'pending_execution' ? 'default' : 'outline'}}",
                  "children": "1. Pending Execution"
                }
              },
              {
                "type": "Text",
                "props": { "variant": "muted", "children": "→" }
              },
              {
                "type": "Badge",
                "props": {
                  "variant": "{{data.contract.entity_versions[0].data.status === 'active' ? 'default' : 'outline'}}",
                  "children": "2. Active"
                }
              },
              {
                "type": "Text",
                "props": { "variant": "muted", "children": "→" }
              },
              {
                "type": "Badge",
                "props": {
                  "variant": "{{data.contract.entity_versions[0].data.status === 'closed' ? 'default' : 'outline'}}",
                  "children": "3. Closed"
                }
              },
              {
                "type": "Text",
                "props": { "variant": "muted", "children": "/" }
              },
              {
                "type": "Badge",
                "props": {
                  "variant": "{{data.contract.entity_versions[0].data.status === 'cancelled' ? 'destructive' : 'outline'}}",
                  "children": "Cancelled"
                }
              }
            ]
          }
        ]
      },
      {
        "type": "Grid",
        "props": { "columns": 2, "gap": 6 },
        "children": [
          {
            "type": "Card",
            "props": { "title": "Contract Information" },
            "children": [
              {
                "type": "Stack",
                "props": { "spacing": 4 },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 1 },
                    "children": [
                      {
                        "type": "Text",
                        "props": { "variant": "muted", "size": "sm", "children": "Customer" }
                      },
                      {
                        "type": "Text",
                        "props": { "weight": "medium", "children": "{{lookupRecordFieldById(data.customers, data.contract.entity_versions[0].data.customer_id, 'name', 'entity_id') || data.contract.entity_versions[0].data.customer_id || 'N/A'}}" }
                      },
                      {
                        "type": "Text",
                        "if": "{{data.contract.entity_versions[0].data.customer_id && lookupRecordFieldById(data.customers, data.contract.entity_versions[0].data.customer_id, 'name', 'entity_id')}}",
                        "props": { "variant": "muted", "size": "xs", "children": "ID: {{data.contract.entity_versions[0].data.customer_id}}" }
                      }
                    ]
                  },
                  {
                    "type": "Stack",
                    "props": { "spacing": 1 },
                    "children": [
                      {
                        "type": "Text",
                        "props": { "variant": "muted", "size": "sm", "children": "Job Site" }
                      },
                      {
                        "type": "Text",
                        "props": { "weight": "medium", "children": "{{lookupRecordFieldById(data.job_sites, data.contract.entity_versions[0].data.job_site_id, 'entity_versions[0].data.name', 'id') || lookupRecordFieldById(data.job_sites, data.contract.entity_versions[0].data.job_site_id, 'source_record_id', 'id') || data.contract.entity_versions[0].data.job_site_id || 'N/A'}}" }
                      },
                      {
                        "type": "Text",
                        "if": "{{data.contract.entity_versions[0].data.job_site_id && (lookupRecordFieldById(data.job_sites, data.contract.entity_versions[0].data.job_site_id, 'entity_versions[0].data.name', 'id') || lookupRecordFieldById(data.job_sites, data.contract.entity_versions[0].data.job_site_id, 'source_record_id', 'id'))}}",
                        "props": { "variant": "muted", "size": "xs", "children": "ID: {{data.contract.entity_versions[0].data.job_site_id}}" }
                      }
                    ]
                  },
                  {
                    "type": "Stack",
                    "props": { "spacing": 1 },
                    "children": [
                      {
                        "type": "Text",
                        "props": { "variant": "muted", "size": "sm", "children": "Contract Number" }
                      },
                      {
                        "type": "Text",
                        "props": { "children": "{{data.contract.entity_versions[0].data.contract_number || 'N/A'}}" }
                      }
                    ]
                  },
                  {
                    "type": "Stack",
                    "props": { "spacing": 1 },
                    "children": [
                      {
                        "type": "Text",
                        "props": { "variant": "muted", "size": "sm", "children": "Status" }
                      },
                      {
                        "type": "Text",
                        "props": { "children": "{{data.contract.entity_versions[0].data.status || 'pending_execution'}}" }
                      }
                    ]
                  },
                  {
                    "type": "Stack",
                    "props": { "spacing": 1 },
                    "children": [
                      {
                        "type": "Text",
                        "props": { "variant": "muted", "size": "sm", "children": "Rental Type" }
                      },
                      {
                        "type": "Text",
                        "props": { "children": "{{data.contract.entity_versions[0].data.rental_type || 'N/A'}}" }
                      }
                    ]
                  },
                  {
                    "type": "Stack",
                    "props": { "spacing": 1 },
                    "children": [
                      {
                        "type": "Text",
                        "props": { "variant": "muted", "size": "sm", "children": "Source Order" }
                      },
                      {
                        "type": "Link",
                        "if": "{{data.contract.entity_versions[0].data.order_id}}",
                        "props": {
                          "to": "/rental/orders/{{data.contract.entity_versions[0].data.order_id}}",
                          "children": "{{lookupRecordFieldById(data.orders, data.contract.entity_versions[0].data.order_id, 'entity_versions[0].data.order_number', 'id') || lookupRecordFieldById(data.orders, data.contract.entity_versions[0].data.order_id, 'entity_versions[0].data.requester_name', 'id') || lookupRecordFieldById(data.orders, data.contract.entity_versions[0].data.order_id, 'entity_versions[0].data.requester_email', 'id') || 'Draft Order'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "if": "{{!data.contract.entity_versions[0].data.order_id}}",
                        "props": { "children": "No linked order" }
                      }
                    ]
                  },
                  {
                    "type": "Stack",
                    "props": { "spacing": 1 },
                    "children": [
                      {
                        "type": "Text",
                        "props": { "variant": "muted", "size": "sm", "children": "Contract ID" }
                      },
                      {
                        "type": "Text",
                        "props": { "variant": "muted", "size": "sm", "children": "{{data.contract.id}}" }
                      }
                    ]
                  },
                  {
                    "type": "Stack",
                    "props": { "spacing": 1 },
                    "children": [
                      {
                        "type": "Text",
                        "props": { "variant": "muted", "size": "sm", "children": "Created" }
                      },
                      {
                        "type": "Text",
                        "props": { "children": "{{data.contract.created_at}}" }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Card",
            "props": { "title": "Line Actions" },
            "children": [
              {
                "type": "Stack",
                "props": { "spacing": 3 },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "variant": "muted",
                      "size": "sm",
                      "children": "Use the buttons below to check out or return individual contract lines."
                    }
                  },
                  {
                    "type": "Button",
                    "if": "{{auth.canOperate}}",
                    "props": {
                      "children": "Check Out Line",
                      "onClick": { "action": "openModal", "modalId": "checkoutLine" }
                    }
                  },
                  {
                    "type": "Button",
                    "if": "{{auth.canOperate}}",
                    "props": {
                      "variant": "outline",
                      "children": "Return Line",
                      "onClick": { "action": "openModal", "modalId": "returnLine" }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Card",
        "props": { "title": "Contract Lines" },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 3 },
            "children": [
              {
                "type": "Stack",
                "props": { "spacing": 2 },
                "children": [
                  {
                    "type": "Stack",
                    "if": "{{data.lines && data.lines.length > 0}}",
                    "each": "{{data.lines}}",
                    "as": "line",
                    "key": "{{line.entity_id}}",
                    "props": { "spacing": 2, "className": "border rounded-lg p-4" },
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "weight": "semibold",
                              "children": "{{lookupRecordFieldById(data.asset_categories, line.category_id, 'asset_category_name', 'asset_category_id') || line.category_id || 'N/A'}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "props": { "variant": "secondary", "children": "{{line.status}}" }
                          }
                        ]
                      },
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "spacing": 3 },
                        "children": [
                          {
                            "type": "Text",
                            "if": "{{line.asset_id}}",
                            "props": { "size": "sm", "variant": "muted", "children": "Asset: {{line.asset_id}}" }
                          },
                          {
                            "type": "Text",
                            "if": "{{line.category_id && lookupRecordFieldById(data.asset_categories, line.category_id, 'asset_category_name', 'asset_category_id')}}",
                            "props": { "size": "sm", "variant": "muted", "children": "Category ID: {{line.category_id}}" }
                          }
                        ]
                      },
                      {
                        "type": "Stack",
                        "props": { "spacing": 1 },
                        "children": [
                          {
                            "type": "Text",
                            "props": { "size": "sm", "variant": "muted", "children": "Line ID: {{line.entity_id}}" }
                          }
                        ]
                      },
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "spacing": 3 },
                        "children": [
                          {
                            "type": "Text",
                            "if": "{{line.actual_start}}",
                            "props": {
                              "size": "sm",
                              "variant": "muted",
                              "children": "Checked out: {{line.actual_start}}"
                            }
                          },
                          {
                            "type": "Text",
                            "if": "{{line.actual_end}}",
                            "props": {
                              "size": "sm",
                              "variant": "muted",
                              "children": "Returned: {{line.actual_end}}"
                            }
                          },
                          {
                            "type": "Text",
                            "if": "{{line.data && line.data.planned_end}}",
                            "props": {
                              "size": "sm",
                              "variant": "muted",
                              "children": "Planned return: {{line.data.planned_end}}"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "if": "{{line.rate_type || line.rate_amount}}",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "Rate: {{line.rate_type || 'N/A'}} · Amount: {{line.rate_amount || 'N/A'}}"
                        }
                      },
                      {
                        "type": "Stack",
                        "if": "{{line.status === 'returned'}}",
                        "props": { "spacing": 1 },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "size": "sm",
                              "variant": "muted",
                              "children": "Invoice status: Returned line ready for billing review · Contract: {{data.contract.entity_versions[0].data.contract_number || 'Rental Contract'}} · Customer: {{lookupRecordFieldById(data.customers, data.contract.entity_versions[0].data.customer_id, 'name', 'entity_id') || data.contract.entity_versions[0].data.customer_id || 'N/A'}} · Job Site: {{lookupRecordFieldById(data.job_sites, data.contract.entity_versions[0].data.job_site_id, 'entity_versions[0].data.name', 'id') || lookupRecordFieldById(data.job_sites, data.contract.entity_versions[0].data.job_site_id, 'source_record_id', 'id') || data.contract.entity_versions[0].data.job_site_id || 'N/A'}}"
                            }
                          },
                          {
                            "type": "Button",
                            "if": "{{data.contractInvoices && data.contractInvoices.length > 0 && data.contractInvoices[0].id ? true : data.contractInvoiceRelationships && data.contractInvoiceRelationships.length > 0 && data.contractInvoiceRelationships[0].parent_id ? true : false}}",
                            "props": {
                              "variant": "outline",
                              "size": "sm",
                              "children": "View invoices for this contract",
                              "onClick": {
                                "action": "navigate",
                                "to": "/entities/invoice/{{data.contractInvoices && data.contractInvoices.length > 0 && data.contractInvoices[0].id || data.contractInvoiceRelationships && data.contractInvoiceRelationships.length > 0 && data.contractInvoiceRelationships[0].parent_id}}"
                              }
                            }
                          },
                          {
                            "type": "Button",
                            "if": "{{data.contractInvoices && data.contractInvoices.length > 0 && data.contractInvoices[0].id ? false : data.contractInvoiceRelationships && data.contractInvoiceRelationships.length > 0 && data.contractInvoiceRelationships[0].parent_id ? false : true}}",
                            "props": {
                              "variant": "outline",
                              "size": "sm",
                              "children": "View invoices for this contract",
                              "onClick": {
                                "action": "navigate",
                                "to": "/entities/invoice?contractId={{params.id}}"
                              }
                            }
                          }
                        ]
                      },
                      {
                       "type": "Stack",
                       "props": { "direction": "horizontal", "spacing": 2 },
                       "children": [
                         {
                           "type": "Button",
                           "if": "{{auth.canOperate && line.status !== 'checked_out' && line.status !== 'returned' && line.status !== 'cancelled'}}",
                           "props": {
                             "size": "sm",
                             "children": "Check Out",
                             "onClick": {
                               "action": "sequence",
                               "actions": [
                                 { "action": "setState", "key": "checkout_line_id", "value": "{{line.entity_id}}" },
                                 { "action": "setState", "key": "checkout_asset_id", "value": "{{line.asset_id || ''}}" },
                                 { "action": "setState", "key": "checkout_actual_start", "value": "" },
                                 { "action": "setState", "key": "checkout_line_status", "value": "{{line.status}}" },
                                 { "action": "setState", "key": "checkout_planned_end", "value": "{{line.data && line.data.planned_end || ''}}" },
                                 { "action": "openModal", "modalId": "checkoutLine" }
                               ]
                             }
                           }
                         },
                         {
                           "type": "Button",
                           "if": "{{auth.canOperate && line.status === 'checked_out'}}",
                           "props": {
                             "variant": "outline",
                             "size": "sm",
                             "children": "Return",
                             "onClick": {
                               "action": "sequence",
                               "actions": [
                                 { "action": "setState", "key": "return_line_id", "value": "{{line.entity_id}}" },
                                 { "action": "setState", "key": "return_actual_end", "value": "" },
                                 { "action": "setState", "key": "return_asset_id", "value": "{{line.asset_id || ''}}" },
                                 { "action": "setState", "key": "return_line_status", "value": "{{line.status}}" },
                                 { "action": "setState", "key": "return_checked_out_date", "value": "{{line.actual_start || ''}}" },
                                 { "action": "openModal", "modalId": "returnLine" }
                               ]
                             }
                           }
                         }
                       ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Text",
                "if": "{{!data.lines || data.lines.length === 0}}",
                "props": {
                  "variant": "muted",
                  "className": "text-center py-8",
                  "children": "No contract lines found for this contract."
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "modals": {
    "checkoutLine": {
      "title": "Check Out Contract Line",
      "description": "Mark a contract line as checked out by assigning an asset and start date.",
      "size": "md",
      "content": {
        "type": "Stack",
        "props": { "spacing": 4 },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 1, "className": "rounded-md border p-3 bg-muted/50" },
            "children": [
              {
                "type": "Text",
                "props": { "size": "sm", "weight": "semibold", "children": "Contract: {{data.contract.entity_versions[0].data.contract_number || 'Rental Contract'}}" }
              },
              {
                "type": "Stack",
                "props": { "direction": "horizontal", "spacing": 3 },
                "children": [
                  {
                    "type": "Text",
                    "if": "{{state.checkout_asset_id}}",
                    "props": { "size": "sm", "variant": "muted", "children": "Asset: {{state.checkout_asset_id}}" }
                  },
                  {
                    "type": "Text",
                    "if": "{{state.checkout_line_status}}",
                    "props": { "size": "sm", "variant": "muted", "children": "Status: {{state.checkout_line_status}}" }
                  },
                  {
                    "type": "Text",
                    "if": "{{state.checkout_planned_end}}",
                    "props": { "size": "sm", "variant": "muted", "children": "Planned return: {{state.checkout_planned_end}}" }
                  }
                ]
              }
            ]
          },
          {
            "type": "Input",
            "props": {
              "label": "Contract Line ID",
              "placeholder": "Select a contract line above or enter the line ID",
              "name": "checkout_line_id",
              "value": "{{state.checkout_line_id || ''}}",
              "onChange": {
                "action": "setState",
                "key": "checkout_line_id",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Input",
            "props": {
              "label": "Asset ID",
              "placeholder": "asset-...",
              "name": "checkout_asset_id",
              "value": "{{state.checkout_asset_id || ''}}",
              "onChange": {
                "action": "setState",
                "key": "checkout_asset_id",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Input",
            "props": {
              "label": "Actual Start Date",
              "placeholder": "YYYY-MM-DD",
              "name": "checkout_actual_start",
              "value": "{{state.checkout_actual_start || ''}}",
              "onChange": {
                "action": "setState",
                "key": "checkout_actual_start",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Stack",
            "props": { "direction": "horizontal", "justify": "end", "spacing": 2 },
            "children": [
              {
                "type": "Button",
                "props": {
                  "variant": "outline",
                  "children": "Cancel",
                  "onClick": { "action": "closeModal" }
                }
              },
              {
                "type": "Button",
                "props": {
                  "children": "Confirm Checkout",
                  "onClick": {
                    "action": "sequence",
                    "actions": [
                      {
                        "action": "apiCall",
                        "operation": "rpc",
                        "function": "rental_upsert_entity_current_state",
                        "data": {
                          "p_entity_type": "rental_contract_line",
                          "p_entity_id": "{{state.checkout_line_id}}",
                          "p_data": {
                            "status": "checked_out",
                            "contract_id": "{{params.id}}",
                            "asset_id": "{{state.checkout_asset_id}}",
                            "actual_start": "{{state.checkout_actual_start}}"
                          }
                        },
                        "onSuccess": {
                          "action": "sequence",
                          "actions": [
                            { "action": "closeModal" },
                            { "action": "setState", "key": "checkout_line_id", "value": "" },
                            { "action": "setState", "key": "checkout_asset_id", "value": "" },
                            { "action": "setState", "key": "checkout_actual_start", "value": "" },
                            { "action": "refetch", "source": "lines" }
                          ]
                        }
                      }
                    ]
                  }
                }
              }
            ]
          }
        ]
      }
    },
    "returnLine": {
      "title": "Return Contract Line",
      "description": "Record the return of a checked-out contract line.",
      "size": "md",
      "content": {
        "type": "Stack",
        "props": { "spacing": 4 },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 1, "className": "rounded-md border p-3 bg-muted/50" },
            "children": [
              {
                "type": "Text",
                "props": { "size": "sm", "weight": "semibold", "children": "Contract: {{data.contract.entity_versions[0].data.contract_number || 'Rental Contract'}}" }
              },
              {
                "type": "Stack",
                "props": { "direction": "horizontal", "spacing": 3 },
                "children": [
                  {
                    "type": "Text",
                    "if": "{{state.return_asset_id}}",
                    "props": { "size": "sm", "variant": "muted", "children": "Asset: {{state.return_asset_id}}" }
                  },
                  {
                    "type": "Text",
                    "if": "{{state.return_line_status}}",
                    "props": { "size": "sm", "variant": "muted", "children": "Status: {{state.return_line_status}}" }
                  },
                  {
                    "type": "Text",
                    "if": "{{state.return_checked_out_date}}",
                    "props": { "size": "sm", "variant": "muted", "children": "Checked out: {{state.return_checked_out_date}}" }
                  }
                ]
              }
            ]
          },
          {
            "type": "Input",
            "props": {
              "label": "Contract Line ID",
              "placeholder": "Select a contract line above or enter the line ID",
              "name": "return_line_id",
              "value": "{{state.return_line_id || ''}}",
              "onChange": {
                "action": "setState",
                "key": "return_line_id",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Input",
            "props": {
              "label": "Actual End Date",
              "placeholder": "YYYY-MM-DD",
              "name": "return_actual_end",
              "value": "{{state.return_actual_end || ''}}",
              "onChange": {
                "action": "setState",
                "key": "return_actual_end",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Alert",
            "props": {
              "variant": "warning",
              "title": "Full return workflow available",
              "description": "For full condition capture and inspection, use the Returns / Check-In screen."
            }
          },
          {
            "type": "Stack",
            "props": { "direction": "horizontal", "justify": "end", "spacing": 2 },
            "children": [
              {
                "type": "Button",
                "props": {
                  "variant": "outline",
                  "children": "Cancel",
                  "onClick": { "action": "closeModal" }
                }
              },
              {
                "type": "Button",
                "props": {
                  "children": "Confirm Return",
                  "onClick": {
                    "action": "sequence",
                    "actions": [
                      {
                        "action": "apiCall",
                        "operation": "rpc",
                        "function": "rental_upsert_entity_current_state",
                        "data": {
                          "p_entity_type": "rental_contract_line",
                          "p_entity_id": "{{state.return_line_id}}",
                          "p_data": "{{mergeRecordFieldById(data.lines, state.return_line_id, 'entity_id', 'status', 'returned', 'contract_id', params.id, 'actual_end', state.return_actual_end)}}"
                        },
                        "onSuccess": {
                          "action": "sequence",
                          "actions": [
                            { "action": "closeModal" },
                            { "action": "setState", "key": "return_line_id", "value": "" },
                            { "action": "setState", "key": "return_actual_end", "value": "" },
                            { "action": "refetch", "source": "lines" },
                            { "action": "refetch", "source": "contractInvoices" },
                            { "action": "refetch", "source": "contractInvoiceRelationships" }
                          ]
                        }
                      }
                    ]
                  }
                }
              }
            ]
          }
        ]
      }
    }
  }
}
