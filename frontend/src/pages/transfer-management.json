{
  "id": "transfer-management",
  "title": "Transfer Management",
  "state": {
    "statusFilter": "",
    "branchFilter": "",
    "projectFilter": "",
    "reqAssetScope": "",
    "reqOriginBranchId": "",
    "reqDestinationBranchId": "",
    "reqShipDate": ""
  },
  "dataSources": {
    "in_transit": {
      "type": "supabase",
      "table": "v_transfer_current",
      "select": "transfer_entity_id, transfer_id, status, asset_id, asset_scope, origin_branch_id, origin_branch_name, destination_branch_id, destination_branch_name, origin_project_id, origin_project_name, destination_project_id, destination_project_name, requested_by, approved_by, dispatched_by, received_by, requested_ship_date, expected_receive_date, actual_ship_at, transfer_exception_reason, created_at, updated_at",
      "filters": [
        { "field": "status", "op": "eq", "value": "in_transit" }
      ],
      "order": [
        { "column": "created_at", "ascending": false }
      ],
      "refetchInterval": 15000
    },
    "transfers": {
      "type": "supabase",
      "table": "v_transfer_history",
      "select": "version_id, transfer_entity_id, transfer_id, version_number, status, asset_id, asset_scope, origin_branch_id, origin_branch_name, destination_branch_id, destination_branch_name, origin_project_id, origin_project_name, destination_project_id, destination_project_name, requested_by, approved_by, dispatched_by, received_by, requested_ship_date, expected_receive_date, actual_ship_at, actual_receive_at, sourcing_decision_id, internal_cost, transfer_exception_reason, transitioned_at, is_current, created_at",
      "order": [
        { "column": "transitioned_at", "ascending": false }
      ],
      "refetchInterval": 30000
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "direction": "horizontal", "justify": "between", "align": "start" },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 1 },
            "children": [
              { "type": "Heading", "props": { "level": 1, "children": "Transfer Management" } },
              {
                "type": "Text",
                "props": {
                  "variant": "muted",
                  "children": "Request, approve, dispatch, and receive equipment transfers between projects and branches. Track in-transit assets and review completed transfer history."
                }
              }
            ]
          },
          {
            "type": "Button",
            "if": "{{auth.canWrite}}",
            "props": {
              "children": "Request Transfer",
              "onClick": { "action": "openModal", "modalId": "requestTransfer" }
            }
          }
        ]
      },
      {
        "type": "Grid",
        "props": { "columns": "repeat(auto-fit, minmax(12rem, 1fr))", "gap": 3 },
        "children": [
          {
            "type": "Input",
            "props": {
              "label": "Status",
              "placeholder": "Filter by status",
              "value": "{{state.statusFilter}}",
              "onChange": {
                "action": "setState",
                "key": "statusFilter",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Input",
            "props": {
              "label": "Branch",
              "placeholder": "Filter by branch name",
              "value": "{{state.branchFilter}}",
              "onChange": {
                "action": "setState",
                "key": "branchFilter",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Input",
            "props": {
              "label": "Project",
              "placeholder": "Filter by project name",
              "value": "{{state.projectFilter}}",
              "onChange": {
                "action": "setState",
                "key": "projectFilter",
                "value": "{{event.target.value}}"
              }
            }
          }
        ]
      },
      {
        "type": "Stack",
        "props": { "spacing": 2 },
        "children": [
          {
            "type": "Stack",
            "props": { "direction": "horizontal", "align": "center", "spacing": 2 },
            "children": [
              { "type": "Heading", "props": { "level": 2, "children": "In Transit" } },
              {
                "type": "Badge",
                "if": "{{data.in_transit.length > 0}}",
                "props": {
                  "variant": "destructive",
                  "children": "{{data.in_transit.length}} in transit"
                }
              },
              {
                "type": "Badge",
                "if": "{{data.in_transit.length === 0}}",
                "props": {
                  "variant": "secondary",
                  "children": "None in transit"
                }
              }
            ]
          },
          {
            "type": "Text",
            "props": {
              "size": "sm",
              "variant": "muted",
              "children": "Equipment currently moving between locations. These assets are unavailable for new rental assignments until received."
            }
          },
          {
            "type": "Text",
            "if": "{{isLoading.in_transit}}",
            "props": { "variant": "muted", "children": "Loading in-transit transfers…" }
          },
          {
            "type": "Alert",
            "if": "{{errors.in_transit}}",
            "props": {
              "variant": "destructive",
              "title": "Unable to load in-transit transfers",
              "description": "Check your connection or retry shortly."
            }
          },
          {
            "type": "Text",
            "if": "{{!isLoading.in_transit && !errors.in_transit && data.in_transit.length === 0}}",
            "props": {
              "variant": "muted",
              "className": "py-4 text-center",
              "children": "No equipment currently in transit."
            }
          },
          {
            "type": "Stack",
            "if": "{{data.in_transit.length > 0}}",
            "props": { "spacing": 3 },
            "children": [
              {
                "type": "Card",
                "each": "{{data.in_transit}}",
                "as": "xfer",
                "key": "intr_{{xfer.transfer_entity_id}}",
                "props": { "className": "border-l-4 border-l-amber-500" },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 2 },
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "weight": "semibold",
                              "children": "{{xfer.asset_scope || xfer.asset_id || 'Equipment'}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "props": {
                              "variant": "secondary",
                              "children": "In Transit"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "align": "center", "spacing": 2 },
                        "children": [
                          {
                            "type": "Stack",
                            "props": { "spacing": 1 },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "size": "xs",
                                  "variant": "muted",
                                  "weight": "medium",
                                  "children": "ORIGIN"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "weight": "semibold",
                                  "children": "{{xfer.origin_branch_name || xfer.origin_branch_id || 'N/A'}}"
                                }
                              },
                              {
                                "type": "Text",
                                "if": "{{xfer.origin_project_name}}",
                                "props": {
                                  "size": "sm",
                                  "variant": "muted",
                                  "children": "Project: {{xfer.origin_project_name}}"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "size": "lg",
                              "variant": "muted",
                              "className": "px-2",
                              "children": "→"
                            }
                          },
                          {
                            "type": "Stack",
                            "props": { "spacing": 1 },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "size": "xs",
                                  "variant": "muted",
                                  "weight": "medium",
                                  "children": "DESTINATION"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "weight": "semibold",
                                  "children": "{{xfer.destination_branch_name || xfer.destination_branch_id || 'N/A'}}"
                                }
                              },
                              {
                                "type": "Text",
                                "if": "{{xfer.destination_project_name}}",
                                "props": {
                                  "size": "sm",
                                  "variant": "muted",
                                  "children": "Project: {{xfer.destination_project_name}}"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "size": "sm",
                              "variant": "muted",
                              "children": "Dispatched by: {{xfer.dispatched_by || 'N/A'}} · Requested ship: {{xfer.requested_ship_date || 'N/A'}} · Expected receive: {{xfer.expected_receive_date || 'N/A'}}"
                            }
                          },
                          {
                            "type": "Stack",
                            "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                            "children": [
                              {
                                "type": "Button",
                                "if": "{{auth.canOperate}}",
                                "props": {
                                  "variant": "outline",
                                  "size": "sm",
                                  "children": "Receive",
                                  "onClick": {
                                    "action": "openModal",
                                    "modalId": "receiveTransfer",
                                    "props": {
                                      "actionTransferEntityId": "{{xfer.transfer_entity_id}}",
                                      "actionAssetId": "{{xfer.asset_id}}",
                                      "actionAssetScope": "{{xfer.asset_scope}}",
                                      "actionOriginBranchId": "{{xfer.origin_branch_id}}",
                                      "actionDestinationBranchId": "{{xfer.destination_branch_id}}",
                                      "actionOriginProjectId": "{{xfer.origin_project_id}}",
                                      "actionDestinationProjectId": "{{xfer.destination_project_id}}",
                                      "actionRequestedBy": "{{xfer.requested_by}}",
                                      "actionApprovedBy": "{{xfer.approved_by}}",
                                      "actionDispatchedBy": "{{xfer.dispatched_by}}",
                                      "actionRequestedShipDate": "{{xfer.requested_ship_date}}",
                                      "actionExpectedReceiveDate": "{{xfer.expected_receive_date}}",
                                      "actionActualShipAt": "{{xfer.actual_ship_at}}",
                                      "actionTransferExceptionReason": "{{xfer.transfer_exception_reason}}"
                                    }
                                  }
                                }
                              },
                              {
                                "type": "Link",
                                "props": {
                                  "to": "/entities/transfer/{{xfer.transfer_entity_id}}",
                                  "children": "View details"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Alert",
                        "if": "{{xfer.transfer_exception_reason}}",
                        "props": {
                          "variant": "warning",
                          "title": "Exception",
                          "description": "{{xfer.transfer_exception_reason}}"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Stack",
        "props": { "spacing": 2 },
        "children": [
          {
            "type": "Stack",
            "props": { "direction": "horizontal", "align": "center", "spacing": 2 },
            "children": [
              { "type": "Heading", "props": { "level": 2, "children": "Transfer History" } },
              {
                "type": "Badge",
                "props": {
                  "variant": "secondary",
                  "children": "{{data.transfers.filter(t => (!state.statusFilter || t.status.toLowerCase().includes(state.statusFilter.toLowerCase())) && (!state.branchFilter || (t.origin_branch_name || '').toLowerCase().includes(state.branchFilter.toLowerCase()) || (t.destination_branch_name || '').toLowerCase().includes(state.branchFilter.toLowerCase())) && (!state.projectFilter || (t.origin_project_name || '').toLowerCase().includes(state.projectFilter.toLowerCase()) || (t.destination_project_name || '').toLowerCase().includes(state.projectFilter.toLowerCase()))).length}} transfer{{data.transfers.filter(t => (!state.statusFilter || t.status.toLowerCase().includes(state.statusFilter.toLowerCase())) && (!state.branchFilter || (t.origin_branch_name || '').toLowerCase().includes(state.branchFilter.toLowerCase()) || (t.destination_branch_name || '').toLowerCase().includes(state.branchFilter.toLowerCase())) && (!state.projectFilter || (t.origin_project_name || '').toLowerCase().includes(state.projectFilter.toLowerCase()) || (t.destination_project_name || '').toLowerCase().includes(state.projectFilter.toLowerCase()))).length === 1 ? '' : 's'}}"
                }
              }
            ]
          },
          {
            "type": "Text",
            "props": {
              "size": "sm",
              "variant": "muted",
              "children": "Full transfer lifecycle history including all status transitions across all projects and branches. Multiple rows per transfer reflect each lifecycle milestone."
            }
          },
          {
            "type": "Text",
            "if": "{{isLoading.transfers}}",
            "props": { "variant": "muted", "children": "Loading transfer history…" }
          },
          {
            "type": "Alert",
            "if": "{{errors.transfers}}",
            "props": {
              "variant": "destructive",
              "title": "Unable to load transfer history",
              "description": "Check your connection or retry shortly."
            }
          },
          {
            "type": "Text",
            "if": "{{!isLoading.transfers && !errors.transfers && data.transfers.length === 0}}",
            "props": {
              "variant": "muted",
              "className": "py-4 text-center",
              "children": "No transfers found."
            }
          },
          {
            "type": "Stack",
            "if": "{{data.transfers.length > 0}}",
            "props": { "spacing": 2 },
            "children": [
              {
                "type": "Card",
                "each": "{{data.transfers.filter(t => (!state.statusFilter || t.status.toLowerCase().includes(state.statusFilter.toLowerCase())) && (!state.branchFilter || (t.origin_branch_name || '').toLowerCase().includes(state.branchFilter.toLowerCase()) || (t.destination_branch_name || '').toLowerCase().includes(state.branchFilter.toLowerCase())) && (!state.projectFilter || (t.origin_project_name || '').toLowerCase().includes(state.projectFilter.toLowerCase()) || (t.destination_project_name || '').toLowerCase().includes(state.projectFilter.toLowerCase())))}}",
                "as": "xfer",
                "key": "{{xfer.version_id}}",
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 2 },
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "weight": "semibold",
                              "children": "{{xfer.asset_scope || xfer.asset_id || 'Equipment'}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "props": {
                              "children": "{{xfer.status}}"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "children": "{{xfer.origin_branch_name || xfer.origin_branch_id || 'N/A'}}{{xfer.origin_project_name ? ' (' + xfer.origin_project_name + ')' : ''}} → {{xfer.destination_branch_name || xfer.destination_branch_id || 'N/A'}}{{xfer.destination_project_name ? ' (' + xfer.destination_project_name + ')' : ''}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "Requested by: {{xfer.requested_by || 'N/A'}} · Approved by: {{xfer.approved_by || 'N/A'}} · Dispatched by: {{xfer.dispatched_by || 'N/A'}} · Received by: {{xfer.received_by || 'N/A'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "Ship: {{xfer.requested_ship_date || 'N/A'}} · Receive: {{xfer.expected_receive_date || 'N/A'}} · Actual ship: {{xfer.actual_ship_at ? formatDate(xfer.actual_ship_at) : 'N/A'}} · Actual receive: {{xfer.actual_receive_at ? formatDate(xfer.actual_receive_at) : 'N/A'}}"
                        }
                      },
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "size": "sm",
                              "variant": "muted",
                              "children": "Transitioned: {{formatDate(xfer.transitioned_at)}}{{xfer.internal_cost ? ' · Cost: $' + xfer.internal_cost : ''}}{{xfer.sourcing_decision_id ? ' · Decision: ' + xfer.sourcing_decision_id : ''}}"
                            }
                          },
                          {
                            "type": "Stack",
                            "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                            "children": [
                              {
                                "type": "Button",
                                "if": "{{auth.canOperate && xfer.is_current && xfer.status === 'requested'}}",
                                "props": {
                                  "variant": "outline",
                                  "size": "sm",
                                  "children": "Approve",
                                  "onClick": {
                                    "action": "openModal",
                                    "modalId": "approveTransfer",
                                    "props": {
                                      "actionTransferEntityId": "{{xfer.transfer_entity_id}}",
                                      "actionAssetId": "{{xfer.asset_id}}",
                                      "actionAssetScope": "{{xfer.asset_scope}}",
                                      "actionOriginBranchId": "{{xfer.origin_branch_id}}",
                                      "actionDestinationBranchId": "{{xfer.destination_branch_id}}",
                                      "actionOriginProjectId": "{{xfer.origin_project_id}}",
                                      "actionDestinationProjectId": "{{xfer.destination_project_id}}",
                                      "actionRequestedBy": "{{xfer.requested_by}}",
                                      "actionRequestedShipDate": "{{xfer.requested_ship_date}}",
                                      "actionExpectedReceiveDate": "{{xfer.expected_receive_date}}",
                                      "actionTransferExceptionReason": "{{xfer.transfer_exception_reason}}"
                                    }
                                  }
                                }
                              },
                              {
                                "type": "Button",
                                "if": "{{auth.canOperate && xfer.is_current && xfer.status === 'approved'}}",
                                "props": {
                                  "variant": "outline",
                                  "size": "sm",
                                  "children": "Dispatch",
                                  "onClick": {
                                    "action": "openModal",
                                    "modalId": "dispatchTransfer",
                                    "props": {
                                      "actionTransferEntityId": "{{xfer.transfer_entity_id}}",
                                      "actionAssetId": "{{xfer.asset_id}}",
                                      "actionAssetScope": "{{xfer.asset_scope}}",
                                      "actionOriginBranchId": "{{xfer.origin_branch_id}}",
                                      "actionDestinationBranchId": "{{xfer.destination_branch_id}}",
                                      "actionOriginProjectId": "{{xfer.origin_project_id}}",
                                      "actionDestinationProjectId": "{{xfer.destination_project_id}}",
                                      "actionRequestedBy": "{{xfer.requested_by}}",
                                      "actionApprovedBy": "{{xfer.approved_by}}",
                                      "actionRequestedShipDate": "{{xfer.requested_ship_date}}",
                                      "actionExpectedReceiveDate": "{{xfer.expected_receive_date}}",
                                      "actionTransferExceptionReason": "{{xfer.transfer_exception_reason}}",
                                      "actionActualShipAt": ""
                                    }
                                  }
                                }
                              },
                              {
                                "type": "Button",
                                "if": "{{auth.canOperate && xfer.is_current && xfer.status === 'in_transit'}}",
                                "props": {
                                  "variant": "outline",
                                  "size": "sm",
                                  "children": "Receive",
                                  "onClick": {
                                    "action": "openModal",
                                    "modalId": "receiveTransfer",
                                    "props": {
                                      "actionTransferEntityId": "{{xfer.transfer_entity_id}}",
                                      "actionAssetId": "{{xfer.asset_id}}",
                                      "actionAssetScope": "{{xfer.asset_scope}}",
                                      "actionOriginBranchId": "{{xfer.origin_branch_id}}",
                                      "actionDestinationBranchId": "{{xfer.destination_branch_id}}",
                                      "actionOriginProjectId": "{{xfer.origin_project_id}}",
                                      "actionDestinationProjectId": "{{xfer.destination_project_id}}",
                                      "actionRequestedBy": "{{xfer.requested_by}}",
                                      "actionApprovedBy": "{{xfer.approved_by}}",
                                      "actionDispatchedBy": "{{xfer.dispatched_by}}",
                                      "actionRequestedShipDate": "{{xfer.requested_ship_date}}",
                                      "actionExpectedReceiveDate": "{{xfer.expected_receive_date}}",
                                      "actionActualShipAt": "{{xfer.actual_ship_at}}",
                                      "actionTransferExceptionReason": "{{xfer.transfer_exception_reason}}"
                                    }
                                  }
                                }
                              },
                              {
                                "type": "Link",
                                "props": {
                                  "to": "/entities/transfer/{{xfer.transfer_entity_id}}",
                                  "children": "View details"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Alert",
                        "if": "{{xfer.transfer_exception_reason}}",
                        "props": {
                          "variant": "warning",
                          "title": "Exception",
                          "description": "{{xfer.transfer_exception_reason}}"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "modals": {
    "requestTransfer": {
      "title": "Request Transfer",
      "size": "md",
      "content": {
        "type": "Stack",
        "props": { "spacing": 4 },
        "children": [
          {
            "type": "Input",
            "props": {
              "label": "Asset / Equipment Description",
              "placeholder": "e.g. Excavator CAT 320 or asset identifier",
              "value": "{{state.reqAssetScope || ''}}",
              "onChange": { "action": "setState", "key": "reqAssetScope", "value": "{{event.target.value}}" }
            }
          },
          {
            "type": "Input",
            "props": {
              "label": "Origin Branch ID",
              "placeholder": "UUID of the source branch",
              "value": "{{state.reqOriginBranchId || ''}}",
              "onChange": { "action": "setState", "key": "reqOriginBranchId", "value": "{{event.target.value}}" }
            }
          },
          {
            "type": "Input",
            "props": {
              "label": "Destination Branch ID",
              "placeholder": "UUID of the destination branch",
              "value": "{{state.reqDestinationBranchId || ''}}",
              "onChange": { "action": "setState", "key": "reqDestinationBranchId", "value": "{{event.target.value}}" }
            }
          },
          {
            "type": "Input",
            "props": {
              "label": "Requested Ship Date",
              "placeholder": "YYYY-MM-DD",
              "value": "{{state.reqShipDate || ''}}",
              "onChange": { "action": "setState", "key": "reqShipDate", "value": "{{event.target.value}}" }
            }
          },
          {
            "type": "Stack",
            "props": { "direction": "horizontal", "justify": "end", "spacing": 2 },
            "children": [
              {
                "type": "Button",
                "props": {
                  "variant": "outline",
                  "children": "Cancel",
                  "onClick": { "action": "closeModal" }
                }
              },
              {
                "type": "Button",
                "props": {
                  "children": "Submit Request",
                  "disabled": "{{!state.reqOriginBranchId || !state.reqDestinationBranchId}}",
                  "onClick": {
                    "action": "apiCall",
                    "operation": "rpc",
                    "function": "create_entity_with_version",
                    "data": {
                      "p_entity_type": "transfer",
                      "p_data": {
                        "status": "requested",
                        "asset_scope": "{{state.reqAssetScope}}",
                        "origin_branch_id": "{{state.reqOriginBranchId}}",
                        "destination_branch_id": "{{state.reqDestinationBranchId}}",
                        "requested_ship_date": "{{state.reqShipDate}}"
                      }
                    },
                    "onSuccess": {
                      "action": "sequence",
                      "actions": [
                        { "action": "closeModal" },
                        { "action": "refetch", "source": "transfers" },
                        { "action": "refetch", "source": "in_transit" }
                      ]
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    },
    "approveTransfer": {
      "title": "Approve Transfer",
      "size": "sm",
      "content": {
        "type": "Stack",
        "props": { "spacing": 4 },
        "children": [
          {
            "type": "Text",
            "props": {
              "children": "Approve transfer of {{state.actionAssetScope || 'equipment'}} from branch {{state.actionOriginBranchId || 'origin'}} to branch {{state.actionDestinationBranchId || 'destination'}}?"
            }
          },
          {
            "type": "Stack",
            "props": { "direction": "horizontal", "justify": "end", "spacing": 2 },
            "children": [
              {
                "type": "Button",
                "props": {
                  "variant": "outline",
                  "children": "Cancel",
                  "onClick": { "action": "closeModal" }
                }
              },
              {
                "type": "Button",
                "props": {
                  "children": "Approve",
                  "onClick": {
                    "action": "apiCall",
                    "operation": "rpc",
                    "function": "rental_upsert_entity_current_state",
                    "data": {
                      "p_entity_type": "transfer",
                      "p_entity_id": "{{state.actionTransferEntityId}}",
                      "p_data": {
                        "status": "approved",
                        "asset_id": "{{state.actionAssetId}}",
                        "asset_scope": "{{state.actionAssetScope}}",
                        "origin_branch_id": "{{state.actionOriginBranchId}}",
                        "destination_branch_id": "{{state.actionDestinationBranchId}}",
                        "origin_project_id": "{{state.actionOriginProjectId}}",
                        "destination_project_id": "{{state.actionDestinationProjectId}}",
                        "requested_by": "{{state.actionRequestedBy}}",
                        "requested_ship_date": "{{state.actionRequestedShipDate}}",
                        "expected_receive_date": "{{state.actionExpectedReceiveDate}}",
                        "transfer_exception_reason": "{{state.actionTransferExceptionReason}}"
                      }
                    },
                    "onSuccess": {
                      "action": "sequence",
                      "actions": [
                        { "action": "closeModal" },
                        { "action": "refetch", "source": "transfers" },
                        { "action": "refetch", "source": "in_transit" }
                      ]
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    },
    "dispatchTransfer": {
      "title": "Dispatch Transfer",
      "size": "sm",
      "content": {
        "type": "Stack",
        "props": { "spacing": 4 },
        "children": [
          {
            "type": "Text",
            "props": {
              "children": "Dispatch transfer of {{state.actionAssetScope || 'equipment'}} to branch {{state.actionDestinationBranchId || 'destination'}}."
            }
          },
          {
            "type": "Input",
            "props": {
              "label": "Actual Ship Date",
              "placeholder": "YYYY-MM-DD",
              "value": "{{state.actionActualShipAt || ''}}",
              "onChange": { "action": "setState", "key": "actionActualShipAt", "value": "{{event.target.value}}" }
            }
          },
          {
            "type": "Stack",
            "props": { "direction": "horizontal", "justify": "end", "spacing": 2 },
            "children": [
              {
                "type": "Button",
                "props": {
                  "variant": "outline",
                  "children": "Cancel",
                  "onClick": { "action": "closeModal" }
                }
              },
              {
                "type": "Button",
                "props": {
                  "children": "Dispatch",
                  "onClick": {
                    "action": "apiCall",
                    "operation": "rpc",
                    "function": "rental_upsert_entity_current_state",
                    "data": {
                      "p_entity_type": "transfer",
                      "p_entity_id": "{{state.actionTransferEntityId}}",
                      "p_data": {
                        "status": "in_transit",
                        "asset_id": "{{state.actionAssetId}}",
                        "asset_scope": "{{state.actionAssetScope}}",
                        "origin_branch_id": "{{state.actionOriginBranchId}}",
                        "destination_branch_id": "{{state.actionDestinationBranchId}}",
                        "origin_project_id": "{{state.actionOriginProjectId}}",
                        "destination_project_id": "{{state.actionDestinationProjectId}}",
                        "requested_by": "{{state.actionRequestedBy}}",
                        "approved_by": "{{state.actionApprovedBy}}",
                        "requested_ship_date": "{{state.actionRequestedShipDate}}",
                        "expected_receive_date": "{{state.actionExpectedReceiveDate}}",
                        "actual_ship_at": "{{state.actionActualShipAt}}",
                        "transfer_exception_reason": "{{state.actionTransferExceptionReason}}"
                      }
                    },
                    "onSuccess": {
                      "action": "sequence",
                      "actions": [
                        { "action": "closeModal" },
                        { "action": "refetch", "source": "transfers" },
                        { "action": "refetch", "source": "in_transit" }
                      ]
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    },
    "receiveTransfer": {
      "title": "Receive Transfer",
      "size": "sm",
      "content": {
        "type": "Stack",
        "props": { "spacing": 4 },
        "children": [
          {
            "type": "Text",
            "props": {
              "children": "Confirm receipt of {{state.actionAssetScope || 'equipment'}} at branch {{state.actionDestinationBranchId || 'destination'}}?"
            }
          },
          {
            "type": "Stack",
            "props": { "direction": "horizontal", "justify": "end", "spacing": 2 },
            "children": [
              {
                "type": "Button",
                "props": {
                  "variant": "outline",
                  "children": "Cancel",
                  "onClick": { "action": "closeModal" }
                }
              },
              {
                "type": "Button",
                "props": {
                  "children": "Confirm Receipt",
                  "onClick": {
                    "action": "apiCall",
                    "operation": "rpc",
                    "function": "rental_upsert_entity_current_state",
                    "data": {
                      "p_entity_type": "transfer",
                      "p_entity_id": "{{state.actionTransferEntityId}}",
                      "p_data": {
                        "status": "received",
                        "asset_id": "{{state.actionAssetId}}",
                        "asset_scope": "{{state.actionAssetScope}}",
                        "origin_branch_id": "{{state.actionOriginBranchId}}",
                        "destination_branch_id": "{{state.actionDestinationBranchId}}",
                        "origin_project_id": "{{state.actionOriginProjectId}}",
                        "destination_project_id": "{{state.actionDestinationProjectId}}",
                        "requested_by": "{{state.actionRequestedBy}}",
                        "approved_by": "{{state.actionApprovedBy}}",
                        "dispatched_by": "{{state.actionDispatchedBy}}",
                        "requested_ship_date": "{{state.actionRequestedShipDate}}",
                        "expected_receive_date": "{{state.actionExpectedReceiveDate}}",
                        "actual_ship_at": "{{state.actionActualShipAt}}",
                        "transfer_exception_reason": "{{state.actionTransferExceptionReason}}"
                      }
                    },
                    "onSuccess": {
                      "action": "sequence",
                      "actions": [
                        { "action": "closeModal" },
                        { "action": "refetch", "source": "transfers" },
                        { "action": "refetch", "source": "in_transit" }
                      ]
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    }
  }
}
