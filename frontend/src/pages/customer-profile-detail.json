{
  "id": "customer-profile-detail",
  "title": "Customer Profile",
  "state": {
    "isEditing": false,
    "editName": "",
    "editCustomerType": "",
    "editTier": "",
    "editIndustry": "",
    "editHqAddress": "",
    "editPreferredPaymentMethod": "",
    "editPreferences": "",
    "saveError": "",
    "log_interaction_type": "call",
    "log_summary": "",
    "log_error": ""
  },
  "modals": {
    "logInteraction": {
      "title": "Log Interaction",
      "size": "md",
      "content": {
        "type": "Stack",
        "props": { "spacing": 4 },
        "children": [
          {
            "type": "Text",
            "if": "{{state.log_error}}",
            "props": { "variant": "destructive", "size": "sm", "children": "{{state.log_error}}" }
          },
          {
            "type": "Select",
            "props": {
              "label": "Interaction Type",
              "name": "log_interaction_type",
              "value": "{{state.log_interaction_type || 'call'}}",
              "options": [
                { "value": "call", "label": "Call" },
                { "value": "email", "label": "Email" },
                { "value": "meeting", "label": "Meeting" },
                { "value": "note", "label": "Internal Note" }
              ],
              "onChange": { "action": "setState", "key": "log_interaction_type", "value": "{{event.target.value}}" }
            }
          },
          {
            "type": "Textarea",
            "props": {
              "label": "Summary",
              "placeholder": "Describe the interaction...",
              "name": "log_summary",
              "value": "{{state.log_summary || ''}}",
              "onChange": { "action": "setState", "key": "log_summary", "value": "{{event.target.value}}" }
            }
          },
          {
            "type": "Stack",
            "props": { "direction": "horizontal", "justify": "end", "spacing": 2 },
            "children": [
              {
                "type": "Button",
                "props": {
                  "variant": "outline",
                  "children": "Cancel",
                  "onClick": { "action": "closeModal" }
                }
              },
              {
                "type": "Button",
                "props": {
                  "children": "Log Interaction",
                  "onClick": {
                    "action": "sequence",
                    "actions": [
                      { "action": "setState", "key": "log_error", "value": "" },
                      {
                        "action": "conditional",
                        "condition": "{{!state.log_summary}}",
                        "then": { "action": "setState", "key": "log_error", "value": "A summary is required." },
                        "else": {
                          "action": "apiCall",
                          "operation": "rpc",
                          "function": "crm_upsert_customer_profile",
                          "data": {
                            "p_source_record_id": "{{data.profile.source_record_id}}",
                            "p_data": {
                              "name": "{{data.profile.name}}",
                              "last_interaction_type": "{{state.log_interaction_type || 'call'}}",
                              "last_interaction_summary": "{{state.log_summary}}"
                            },
                            "p_enrich_only": true
                          },
                          "onSuccess": {
                            "action": "sequence",
                            "actions": [
                              { "action": "closeModal" },
                              { "action": "setState", "key": "log_summary", "value": "" },
                              { "action": "setState", "key": "log_interaction_type", "value": "call" },
                              { "action": "refetch", "source": "profile" },
                              { "action": "refetch", "source": "communication_timeline" }
                            ]
                          },
                          "onError": {
                            "action": "setState",
                            "key": "log_error",
                            "value": "Failed to log interaction. Please try again."
                          }
                        }
                      }
                    ]
                  }
                }
              }
            ]
          }
        ]
      }
    }
  },
  "dataSources": {
    "profile": {
      "type": "supabase",
      "table": "crm_customer_profile_current",
      "select": "entity_id, source_record_id, name, customer_type, tier, industry, hq_address, preferred_payment_method, preferences, payment_methods, balance, credit_limit, avg_days_to_pay, payment_issue_flag, last_interaction_type, last_interaction_summary, entity_version_id, version_number, valid_from, created_at, data",
      "filters": [
        { "field": "entity_id", "op": "eq", "value": "{{params.id}}" }
      ],
      "single": true
    },
    "contacts": {
      "type": "supabase",
      "table": "relationships_v2",
      "select": "id, child_id, entities!relationships_v2_child_id_fkey(id, entity_versions!inner(data, is_current))",
      "filters": [
        { "field": "relationship_type", "op": "eq", "value": "customer_has_contact" },
        { "field": "parent_id", "op": "eq", "value": "{{params.id}}" },
        { "field": "is_current", "op": "eq", "value": true }
      ]
    },
    "notes": {
      "type": "supabase",
      "table": "relationships_v2",
      "select": "id, child_id, entities!relationships_v2_child_id_fkey(id, entity_versions!inner(data, is_current))",
      "filters": [
        { "field": "relationship_type", "op": "eq", "value": "customer_has_note" },
        { "field": "parent_id", "op": "eq", "value": "{{params.id}}" },
        { "field": "is_current", "op": "eq", "value": true }
      ]
    },
    "documents": {
      "type": "supabase",
      "table": "relationships_v2",
      "select": "id, child_id, entities!relationships_v2_child_id_fkey(id, entity_versions!inner(data, is_current))",
      "filters": [
        { "field": "relationship_type", "op": "eq", "value": "customer_has_document" },
        { "field": "parent_id", "op": "eq", "value": "{{params.id}}" },
        { "field": "is_current", "op": "eq", "value": true }
      ]
    },
    "billing_accounts": {
      "type": "supabase",
      "table": "relationships_v2",
      "select": "id, child_id, entities!relationships_v2_child_id_fkey(id, entity_versions!inner(data, is_current))",
      "filters": [
        { "field": "relationship_type", "op": "eq", "value": "customer_has_billing_account" },
        { "field": "parent_id", "op": "eq", "value": "{{params.id}}" },
        { "field": "is_current", "op": "eq", "value": true }
      ]
    },
    "issues": {
      "type": "supabase",
      "table": "crm_customer_issue_current",
      "select": "issue_entity_id, issue_source_record_id, customer_id, billing_account_id, issue_type, status, severity, owner, resolution_notes, opened_at, resolved_at",
      "filters": [
        { "field": "customer_id", "op": "eq", "value": "{{params.id}}" }
      ],
      "order": [{ "column": "opened_at", "ascending": false }]
    },
    "communication_timeline": {
      "type": "supabase",
      "table": "crm_customer_communication_timeline",
      "select": "timeline_event_id, customer_id, billing_account_id, occurred_at, interaction_type, interaction_label, summary, linked_entity_id, linked_entity_type",
      "filters": [
        { "field": "customer_id", "op": "eq", "value": "{{params.id}}" }
      ],
      "order": [{ "column": "occurred_at", "ascending": false }]
    },
    "versions": {
      "type": "supabase",
      "table": "entity_versions",
      "select": "id, version_number, valid_from, valid_to, is_current, data",
      "filters": [
        { "field": "entity_id", "op": "eq", "value": "{{params.id}}" }
      ],
      "order": [{ "column": "version_number", "ascending": false }]
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "if": "{{isLoading.profile}}",
        "props": { "spacing": 4 },
        "children": [
          { "type": "Skeleton", "props": { "height": 18, "width": "7rem" } },
          { "type": "Skeleton", "props": { "height": 40, "width": "18rem" } }
        ]
      },
      {
        "type": "Stack",
        "if": "{{!isLoading.profile}}",
        "props": { "spacing": 6 },
        "children": [
          {
            "type": "Stack",
            "props": { "direction": "horizontal", "justify": "between", "align": "start" },
            "children": [
              {
                "type": "Stack",
                "props": { "spacing": 2 },
                "children": [
                  {
                    "type": "Link",
                    "props": {
                      "to": "/crm/customers",
                      "children": "← Customers"
                    }
                  },
                  {
                    "type": "Heading",
                    "props": {
                      "level": 1,
                      "children": "{{data.profile.name || data.profile.source_record_id}}"
                    }
                  },
                  {
                    "type": "Stack",
                    "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                    "children": [
                      {
                        "type": "Badge",
                        "props": {
                          "variant": "outline",
                          "children": "{{data.profile.tier || 'standard'}}"
                        }
                      },
                      {
                        "type": "Badge",
                        "props": {
                          "variant": "secondary",
                          "children": "{{data.profile.customer_type || 'local'}}"
                        }
                      },
                      {
                        "type": "Badge",
                        "if": "{{data.profile.payment_issue_flag - 0 === 1}}",
                        "props": {
                          "variant": "destructive",
                          "children": "Payment Issue"
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Button",
                "if": "{{auth.canOperate}}",
                "props": {
                  "variant": "outline",
                  "children": "Log Interaction",
                  "onClick": { "action": "openModal", "modalId": "logInteraction" }
                }
              }
            ]
          },
          {
            "type": "Grid",
            "props": { "columns": "repeat(auto-fit, minmax(240px, 1fr))", "gap": 4 },
            "children": [
              {
                "type": "Card",
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 3 },
                    "children": [
                      {
                        "type": "Text",
                        "props": { "weight": "semibold", "children": "Balance" }
                      },
                      {
                        "type": "Heading",
                        "props": {
                          "level": 2,
                          "children": "${{data.profile.balance || 0}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "variant": "muted",
                          "size": "sm",
                          "children": "Credit limit: ${{data.profile.credit_limit || 0}}"
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Grid",
                "props": { "columns": "repeat(auto-fit, minmax(320px, 1fr))", "gap": 6 },
                "children": [
                  {
                    "type": "Card",
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "spacing": 4 },
                        "children": [
                          {
                            "type": "Heading",
                            "props": { "level": 3, "children": "Payment & Service Issues" }
                          },
                          {
                            "type": "Stack",
                            "props": { "spacing": 2 },
                            "children": [
                              {
                                "type": "Stack",
                                "each": "{{data.issues}}",
                                "as": "issue",
                                "key": "{{issue.issue_entity_id}}",
                                "props": {
                                  "spacing": 1,
                                  "className": "p-3 border rounded-lg"
                                },
                                "children": [
                                  {
                                    "type": "Stack",
                                    "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                                    "children": [
                                      {
                                        "type": "Badge",
                                        "props": {
                                          "variant": "outline",
                                          "children": "{{issue.issue_type === 'payment_issue' ? 'Payment Issue' : (issue.issue_type || 'issue')}}"
                                        }
                                      },
                                      {
                                        "type": "Badge",
                                        "props": {
                                          "variant": "secondary",
                                          "children": "{{issue.status || 'open'}}"
                                        }
                                      },
                                      {
                                        "type": "Badge",
                                        "props": {
                                          "variant": "destructive",
                                          "children": "{{issue.severity || 'medium'}}"
                                        }
                                      }
                                    ]
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "variant": "muted",
                                      "size": "sm",
                                      "children": "Owner: {{issue.owner || 'unassigned'}} · Opened: {{issue.opened_at}}"
                                    }
                                  },
                                  {
                                    "type": "Text",
                                    "if": "{{issue.resolution_notes}}",
                                    "props": {
                                      "variant": "muted",
                                      "size": "sm",
                                      "children": "Resolution: {{issue.resolution_notes}}"
                                    }
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "if": "{{!data.issues || data.issues.length === 0}}",
                            "props": {
                              "variant": "muted",
                              "size": "sm",
                              "children": "No customer issues recorded."
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Card",
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "spacing": 4 },
                        "children": [
                          {
                            "type": "Heading",
                            "props": { "level": 3, "children": "Communication Timeline" }
                          },
                          {
                            "type": "Stack",
                            "props": { "spacing": 2 },
                            "children": [
                              {
                                "type": "Stack",
                                "each": "{{data.communication_timeline}}",
                                "as": "event",
                                "key": "{{event.timeline_event_id}}",
                                "props": {
                                  "spacing": 1,
                                  "className": "p-3 border rounded-lg"
                                },
                                "children": [
                                  {
                                    "type": "Stack",
                                    "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                                    "children": [
                                      {
                                        "type": "Badge",
                                        "props": {
                                          "variant": "outline",
                                          "children": "{{event.interaction_label || event.interaction_type}}"
                                        }
                                      },
                                      {
                                        "type": "Text",
                                        "props": {
                                          "variant": "muted",
                                          "size": "sm",
                                          "children": "{{event.occurred_at}}"
                                        }
                                      }
                                    ]
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "size": "sm",
                                      "children": "{{event.summary || 'No summary provided'}}"
                                    }
                                  },
                                  {
                                    "type": "Text",
                                    "if": "{{event.linked_entity_type || event.linked_entity_id}}",
                                    "props": {
                                      "variant": "muted",
                                      "size": "sm",
                                      "children": "Linked: {{event.linked_entity_type || 'record'}} · {{event.linked_entity_id || 'N/A'}}"
                                    }
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "type": "Stack",
                            "if": "{{data.profile.last_interaction_summary && (!data.communication_timeline || data.communication_timeline.length === 0 || data.communication_timeline[0].summary !== data.profile.last_interaction_summary)}}",
                            "props": {
                              "spacing": 1,
                              "className": "p-3 border rounded-lg"
                            },
                            "children": [
                              {
                                "type": "Stack",
                                "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                                "children": [
                                  {
                                    "type": "Badge",
                                    "props": {
                                      "variant": "outline",
                                      "children": "{{data.profile.last_interaction_type === 'email' ? 'Email' : data.profile.last_interaction_type === 'call' ? 'Call' : data.profile.last_interaction_type === 'meeting' ? 'Meeting' : data.profile.last_interaction_type === 'note' ? 'Internal Note' : (data.profile.last_interaction_type || 'Interaction')}}"
                                    }
                                  }
                                ]
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "size": "sm",
                                  "children": "{{data.profile.last_interaction_summary}}"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "if": "{{(!data.communication_timeline || data.communication_timeline.length === 0) && !data.profile.last_interaction_summary}}",
                            "props": {
                              "variant": "muted",
                              "size": "sm",
                              "children": "No communication events yet."
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Card",
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 3 },
                    "children": [
                      {
                        "type": "Text",
                        "props": { "weight": "semibold", "children": "Avg Days to Pay" }
                      },
                      {
                        "type": "Heading",
                        "props": {
                          "level": 2,
                          "children": "{{data.profile.avg_days_to_pay || 'N/A'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "variant": "muted",
                          "size": "sm",
                          "children": "Rolling average across invoices"
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Card",
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 3 },
                    "children": [
                      {
                        "type": "Text",
                        "props": { "weight": "semibold", "children": "Industry" }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "lg",
                          "children": "{{data.profile.industry || 'N/A'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "variant": "muted",
                          "size": "sm",
                          "children": "{{data.profile.hq_address || ''}}"
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Card",
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 3 },
                    "children": [
                      {
                        "type": "Text",
                        "props": { "weight": "semibold", "children": "Payment Method" }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "lg",
                          "children": "{{data.profile.preferred_payment_method || 'Not set'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "variant": "muted",
                          "size": "sm",
                          "children": "Masked card / ACH references only"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Grid",
            "props": { "columns": "repeat(auto-fit, minmax(320px, 1fr))", "gap": 6 },
            "children": [
              {
                "type": "Card",
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 4 },
                    "children": [
                      {
                        "type": "Heading",
                        "props": { "level": 3, "children": "Contacts" }
                      },
                      {
                        "type": "Stack",
                        "props": { "spacing": 2 },
                        "children": [
                          {
                            "type": "Stack",
                            "each": "{{data.contacts}}",
                            "as": "rel",
                            "key": "{{rel.id}}",
                            "props": {
                              "spacing": 1,
                              "className": "p-3 border rounded-lg"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "weight": "medium",
                                  "children": "{{rel.entities.entity_versions[0].data.name || rel.child_id}}"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "variant": "muted",
                                  "size": "sm",
                                  "children": "{{rel.entities.entity_versions[0].data.role || ''}} · {{rel.entities.entity_versions[0].data.email || ''}}"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "variant": "muted",
                                  "size": "sm",
                                  "children": "{{rel.entities.entity_versions[0].data.phone || ''}}"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "if": "{{!data.contacts || data.contacts.length === 0}}",
                        "props": {
                          "variant": "muted",
                          "size": "sm",
                          "children": "No contacts linked."
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Card",
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 4 },
                    "children": [
                      {
                        "type": "Heading",
                        "props": { "level": 3, "children": "Billing Accounts" }
                      },
                      {
                        "type": "Stack",
                        "props": { "spacing": 2 },
                        "children": [
                          {
                            "type": "Stack",
                            "each": "{{data.billing_accounts}}",
                            "as": "rel",
                            "key": "{{rel.id}}",
                            "props": {
                              "spacing": 1,
                              "className": "p-3 border rounded-lg"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "weight": "medium",
                                  "children": "{{rel.entities.entity_versions[0].data.name || rel.child_id}}"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "variant": "muted",
                                  "size": "sm",
                                  "children": "Account: {{rel.entities.entity_versions[0].data.account_number || 'N/A'}} · Terms: {{rel.entities.entity_versions[0].data.payment_terms || 'N/A'}}"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "if": "{{!data.billing_accounts || data.billing_accounts.length === 0}}",
                        "props": {
                          "variant": "muted",
                          "size": "sm",
                          "children": "No billing accounts linked."
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Card",
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 4 },
                    "children": [
                      {
                        "type": "Heading",
                        "props": { "level": 3, "children": "Documents" }
                      },
                      {
                        "type": "Stack",
                        "props": { "spacing": 2 },
                        "children": [
                          {
                            "type": "Stack",
                            "each": "{{data.documents}}",
                            "as": "rel",
                            "key": "{{rel.id}}",
                            "props": {
                              "spacing": 1,
                              "className": "p-3 border rounded-lg"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "weight": "medium",
                                  "children": "{{rel.entities.entity_versions[0].data.title || rel.entities.entity_versions[0].data.document_type || rel.child_id}}"
                                }
                              },
                              {
                                "type": "Stack",
                                "props": { "direction": "horizontal", "spacing": 2 },
                                "children": [
                                  {
                                    "type": "Badge",
                                    "props": {
                                      "variant": "outline",
                                      "children": "{{rel.entities.entity_versions[0].data.document_type || 'document'}}"
                                    }
                                  },
                                  {
                                    "type": "Badge",
                                    "props": {
                                      "variant": "secondary",
                                      "children": "{{rel.entities.entity_versions[0].data.status || 'pending'}}"
                                    }
                                  }
                                ]
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "variant": "muted",
                                  "size": "sm",
                                  "children": "Expires: {{rel.entities.entity_versions[0].data.expiry_date || 'N/A'}}"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "if": "{{!data.documents || data.documents.length === 0}}",
                        "props": {
                          "variant": "muted",
                          "size": "sm",
                          "children": "No documents on file."
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Card",
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 4 },
                    "children": [
                      {
                        "type": "Heading",
                        "props": { "level": 3, "children": "Notes" }
                      },
                      {
                        "type": "Stack",
                        "props": { "spacing": 2 },
                        "children": [
                          {
                            "type": "Stack",
                            "each": "{{data.notes}}",
                            "as": "rel",
                            "key": "{{rel.id}}",
                            "props": {
                              "spacing": 1,
                              "className": "p-3 border rounded-lg"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "size": "sm",
                                  "children": "{{rel.entities.entity_versions[0].data.body || ''}}"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "variant": "muted",
                                  "size": "sm",
                                  "children": "{{rel.entities.entity_versions[0].data.note_type || 'internal'}} · {{rel.entities.entity_versions[0].data.created_by || ''}}"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "if": "{{!data.notes || data.notes.length === 0}}",
                        "props": {
                          "variant": "muted",
                          "size": "sm",
                          "children": "No notes recorded."
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Card",
            "children": [
              {
                "type": "Stack",
                "props": { "spacing": 4 },
                "children": [
                  {
                    "type": "Heading",
                    "props": { "level": 3, "children": "Profile History" }
                  },
                  {
                    "type": "Stack",
                    "props": { "spacing": 2 },
                    "children": [
                      {
                        "type": "Stack",
                        "each": "{{data.versions}}",
                        "as": "ver",
                        "key": "{{ver.id}}",
                        "props": {
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center",
                          "className": "p-3 border rounded-lg"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "size": "sm",
                              "children": "Version {{ver.version_number}} · {{ver.valid_from}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "props": {
                              "variant": "{{ver.is_current ? 'default' : 'outline'}}",
                              "children": "{{ver.is_current ? 'Current' : 'Historical'}}"
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "if": "{{!data.versions || data.versions.length === 0}}",
                    "props": {
                      "variant": "muted",
                      "size": "sm",
                      "children": "No version history."
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
