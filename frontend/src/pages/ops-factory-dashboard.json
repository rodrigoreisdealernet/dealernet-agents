{
  "id": "ops-factory-dashboard",
  "title": "Operations Dashboard",
  "state": {},
  "dataSources": {
    "agent_status": {
      "type": "supabase",
      "table": "ops_agent_status_view",
      "select": "tenant_id, agent_key, enabled, last_run_id, last_run_started_at, last_run_finished_at, last_run_status, next_run_at, total_runs, succeeded_runs, failed_runs, pending_findings, has_pending_badge, identified_delta",
      "order": [
        { "column": "pending_findings", "ascending": false },
        { "column": "agent_key", "ascending": true }
      ],
      "refetchInterval": 15000
    },
    "kpis": {
      "type": "supabase",
      "table": "ops_finding_kpis",
      "select": "tenant_id, pending_count, recoverable_delta, approved_this_cycle, findings_last_24h",
      "order": [
        { "column": "pending_count", "ascending": false }
      ],
      "limit": 1,
      "refetchInterval": 15000
    },
    "recent_activity": {
      "type": "supabase",
      "table": "ops_audit_trail_view",
      "select": "row_id, entity_id, entity_type, entity_name, fact_key, fact_label, observed_at, data_payload, metadata, source_id, point_order",
      "order": [
        { "column": "observed_at", "ascending": false },
        { "column": "point_order", "ascending": false }
      ],
      "limit": 10,
      "refetchInterval": 15000
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "spacing": 1 },
        "children": [
          {
            "type": "Heading",
            "props": { "level": 1, "children": "Operations Dashboard" }
          },
          {
            "type": "Text",
            "props": {
              "variant": "muted",
              "children": "Track revenue opportunities, fleet audits, and recent review activity across your rental business."
            }
          }
        ]
      },
      {
        "type": "Text",
        "if": "{{isLoading.kpis || isLoading.agent_status}}",
        "props": {
          "variant": "muted",
          "children": "Loading operations dashboard..."
        }
      },
      {
        "type": "Alert",
        "if": "{{errors.kpis ? !data.kpis || data.kpis.length === 0 : false}}",
        "props": {
          "variant": "destructive",
          "title": "Unable to load operations dashboard",
          "description": "Retry shortly."
        }
      },
      {
        "type": "Grid",
        "if": "{{!errors.kpis && data.kpis && data.kpis.length > 0}}",
        "props": { "columns": "repeat(auto-fit, minmax(14rem, 1fr))", "gap": 4 },
        "children": [
          {
            "type": "Card",
            "props": { "title": "Items awaiting review" },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "level": 2,
                  "size": "3xl",
                  "children": "{{data.kpis[0].pending_count || 0}}"
                }
              },
              {
                "type": "Link",
                "props": {
                  "to": "/ops/findings",
                  "children": "Open audit history"
                }
              }
            ]
          },
          {
            "type": "Card",
            "props": { "title": "Revenue opportunities" },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "level": 2,
                  "size": "3xl",
                  "children": "{{formatCurrency(data.kpis[0].recoverable_delta || 0, data.kpis[0].reporting_currency_code || data.reporting_currency_code || 'USD')}}"
                }
              }
            ]
          },
          {
            "type": "Card",
            "props": { "title": "Approved this cycle" },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "level": 2,
                  "size": "3xl",
                  "children": "{{data.kpis[0].approved_this_cycle || 0}}"
                }
              }
            ]
          },
          {
            "type": "Card",
            "props": { "title": "Audit events (24h)" },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "level": 2,
                  "size": "3xl",
                  "children": "{{data.kpis[0].findings_last_24h || 0}}"
                }
              }
            ]
          }
        ]
      },
      {
        "type": "Card",
        "props": { "title": "Business workflows" },
        "children": [
          {
            "type": "Alert",
            "if": "{{errors.agent_status}}",
            "props": {
              "variant": "destructive",
              "title": "Could not load business workflows",
              "description": "{{errors.agent_status.message || 'Retry shortly.'}}"
            }
          },
          {
            "type": "Text",
            "if": "{{!errors.agent_status ? !data.agent_status || data.agent_status.length === 0 : false}}",
            "props": {
              "variant": "muted",
              "className": "py-6 text-center",
              "children": "No business workflows are configured for this tenant yet."
            }
          },
          {
            "type": "Grid",
            "if": "{{!errors.agent_status && data.agent_status && data.agent_status.length > 0}}",
            "props": { "columns": "repeat(auto-fit, minmax(18rem, 1fr))", "gap": 4 },
            "children": [
              {
                "type": "Card",
                "each": "{{data.agent_status}}",
                "as": "agent",
                "key": "{{agent.agent_key}}",
                "props": {
                  "className": "{{agent.enabled ? '' : 'opacity-60'}}",
                  "title": "{{formatOpsAgentLabel(agent.agent_key)}}"
                },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 2 },
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Badge",
                            "props": {
                              "variant": "{{agent.enabled ? 'secondary' : 'outline'}}",
                              "children": "{{agent.enabled ? 'Enabled' : 'Disabled'}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "if": "{{agent.pending_findings > 0}}",
                            "props": {
                              "variant": "destructive",
                              "children": "{{agent.pending_findings}} pending"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "Last run: {{agent.last_run_status || 'not yet run'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "Last started: {{formatDate(agent.last_run_started_at)}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "Next run: {{formatDate(agent.next_run_at)}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "Runs: {{agent.total_runs || 0}} total · {{agent.succeeded_runs || 0}} succeeded"
                        }
                      },
                      {
                        "type": "Text",
                        "if": "{{agent.identified_delta !== 0}}",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "Identified: {{formatCurrency(agent.identified_delta, agent.reporting_currency_code || data.kpis[0].reporting_currency_code || 'USD')}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "Queue context: {{agent.pending_findings || 0}} pending for tenant {{agent.tenant_id || 'current tenant'}}"
                        }
                      },
                      {
                        "type": "Link",
                        "props": {
                          "to": "{{getOpsWorkflowRoute(agent.agent_key)}}",
                          "children": "{{getOpsWorkflowLinkLabel(agent.agent_key)}}"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Card",
        "props": { "title": "Recent audit activity" },
        "children": [
          {
            "type": "Alert",
            "if": "{{errors.recent_activity}}",
            "props": {
              "variant": "destructive",
              "title": "Could not load recent audit activity",
              "description": "{{errors.recent_activity.message || 'Retry shortly.'}}"
            }
          },
          {
            "type": "Text",
            "if": "{{!errors.recent_activity ? !data.recent_activity || data.recent_activity.length === 0 : false}}",
            "props": {
              "variant": "muted",
              "className": "py-4",
              "children": "No recent audit events."
            }
          },
          {
            "type": "Stack",
            "if": "{{!errors.recent_activity && data.recent_activity && data.recent_activity.length > 0}}",
            "props": { "spacing": 2 },
            "children": [
              {
                "type": "Stack",
                "each": "{{data.recent_activity}}",
                "as": "event",
                "key": "{{event.entity_id}}-{{event.point_order}}",
                "props": { "spacing": 1, "className": "rounded border p-3" },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "weight": "semibold",
                      "children": "{{formatOpsAuditLabel(event.fact_label || event.fact_key)}}"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "variant": "muted",
                      "children": "Finding {{event.metadata.finding_id || event.data_payload.finding_id || event.metadata.finding_type || 'N/A'}} · Contract {{event.metadata.contract_label || event.data_payload.contract_label || event.entity_name || event.entity_id || 'N/A'}} · Customer {{event.metadata.customer_name || event.data_payload.customer_name || 'N/A'}}"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "variant": "muted",
                      "children": "{{event.entity_name || event.entity_type}} · {{formatDate(event.observed_at)}}"
                    }
                  },
                  {
                    "type": "Link",
                    "props": {
                      "to": "/ops/audit/{{event.entity_id}}",
                      "search": { "event": "{{event.row_id}}" },
                      "children": "View audit trail"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
