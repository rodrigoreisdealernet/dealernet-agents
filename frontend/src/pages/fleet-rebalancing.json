{
  "id": "fleet-rebalancing",
  "title": "Fleet Rebalancing Recommendations",
  "state": {
    "categoryFilter": "",
    "branchFilter": ""
  },
  "dataSources": {
    "rebalancing": {
      "type": "supabase",
      "table": "v_fleet_idle_rebalancing",
      "select": "surplus_branch_id, surplus_branch_name, asset_category_id, asset_category_name, idle_count, deficit_branch_id, deficit_branch_name, open_demand_count, demand_gap, suggested_transfer_qty",
      "order": [
        { "column": "suggested_transfer_qty", "ascending": false },
        { "column": "demand_gap", "ascending": false }
      ],
      "refetchInterval": 30000
    },
    "pending_transfers": {
      "type": "supabase",
      "table": "ops_findings_view",
      "select": "id, finding_type, severity, status, proposed_action, rationale, confidence, fingerprint, created_at",
      "filters": [
        { "field": "agent_key", "op": "eq", "value": "fleet-auditor" },
        { "field": "status", "op": "eq", "value": "pending_approval" }
      ],
      "order": [
        { "column": "created_at", "ascending": false }
      ],
      "refetchInterval": 10000
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "spacing": 1 },
        "children": [
          { "type": "Heading", "props": { "level": 1, "children": "Fleet Rebalancing Recommendations" } },
          {
            "type": "Text",
            "props": {
              "variant": "muted",
              "children": "Branch-level idle inventory signals and suggested cross-branch transfer moves. Idle assets at surplus branches are matched to open demand at deficit branches for the same category."
            }
          }
        ]
      },
      {
        "type": "Grid",
        "props": { "columns": "repeat(auto-fit, minmax(12rem, 1fr))", "gap": 3 },
        "children": [
          {
            "type": "Input",
            "props": {
              "label": "Category",
              "placeholder": "Filter by category name",
              "value": "{{state.categoryFilter}}",
              "onChange": {
                "action": "setState",
                "key": "categoryFilter",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Input",
            "props": {
              "label": "Branch",
              "placeholder": "Filter by branch name",
              "value": "{{state.branchFilter}}",
              "onChange": {
                "action": "setState",
                "key": "branchFilter",
                "value": "{{event.target.value}}"
              }
            }
          }
        ]
      },
      {
        "type": "Text",
        "if": "{{isLoading.rebalancing}}",
        "props": { "variant": "muted", "children": "Loading rebalancing signals…" }
      },
      {
        "type": "Alert",
        "if": "{{errors.rebalancing}}",
        "props": {
          "variant": "destructive",
          "title": "Unable to load rebalancing data",
          "description": "Check your connection or retry shortly."
        }
      },
      {
        "type": "Text",
        "if": "{{!isLoading.rebalancing && !errors.rebalancing && data.rebalancing.length === 0}}",
        "props": {
          "variant": "muted",
          "className": "py-8 text-center",
          "children": "No rebalancing opportunities detected. All branches are balanced for current demand."
        }
      },
      {
        "type": "Stack",
        "if": "{{data.rebalancing.length > 0}}",
        "props": { "spacing": 2 },
        "children": [
          {
            "type": "Stack",
            "props": { "direction": "horizontal", "align": "center", "spacing": 2 },
            "children": [
              {
                "type": "Heading",
                "props": { "level": 2, "children": "Rebalancing Opportunities" }
              },
              {
                "type": "Badge",
                "props": {
                  "variant": "secondary",
                  "children": "{{data.rebalancing.length}} candidate{{data.rebalancing.length === 1 ? '' : 's'}}"
                }
              }
            ]
          },
          {
            "type": "Stack",
            "props": { "spacing": 3 },
            "children": [
              {
                "type": "Card",
                "each": "{{data.rebalancing.filter(r => (!state.categoryFilter || r.asset_category_name.toLowerCase().includes(state.categoryFilter.toLowerCase())) && (!state.branchFilter || r.surplus_branch_name.toLowerCase().includes(state.branchFilter.toLowerCase()) || r.deficit_branch_name.toLowerCase().includes(state.branchFilter.toLowerCase())))}}",
                "as": "move",
                "key": "{{move.surplus_branch_id}}-{{move.asset_category_id}}-{{move.deficit_branch_id}}",
                "props": { "className": "border-l-4 border-l-amber-500" },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 3 },
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "weight": "semibold",
                              "children": "{{move.asset_category_name}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "props": {
                              "variant": "destructive",
                              "children": "Move {{move.suggested_transfer_qty}}"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "align": "center", "spacing": 2 },
                        "children": [
                          {
                            "type": "Stack",
                            "props": { "spacing": 1 },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "size": "xs",
                                  "variant": "muted",
                                  "weight": "medium",
                                  "children": "SURPLUS BRANCH"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "weight": "semibold",
                                  "children": "{{move.surplus_branch_name}}"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "size": "sm",
                                  "variant": "muted",
                                  "children": "{{move.idle_count}} idle asset{{move.idle_count === 1 ? '' : 's'}}"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "size": "lg",
                              "variant": "muted",
                              "className": "px-2",
                              "children": "→"
                            }
                          },
                          {
                            "type": "Stack",
                            "props": { "spacing": 1 },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "size": "xs",
                                  "variant": "muted",
                                  "weight": "medium",
                                  "children": "DEFICIT BRANCH"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "weight": "semibold",
                                  "children": "{{move.deficit_branch_name}}"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "size": "sm",
                                  "variant": "muted",
                                  "children": "{{move.open_demand_count}} open order{{move.open_demand_count === 1 ? '' : 's'}}, {{move.demand_gap}} unfulfilled"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "size": "sm",
                              "variant": "muted",
                              "children": "Demand imbalance: {{move.demand_gap}} unit{{move.demand_gap === 1 ? '' : 's'}} short at {{move.deficit_branch_name}} · {{move.idle_count}} idle at {{move.surplus_branch_name}}"
                            }
                          },
                          {
                            "type": "Link",
                            "props": {
                              "to": "/ops/fleet-audits",
                              "children": "Review transfer findings"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Stack",
        "props": { "spacing": 2 },
        "children": [
          {
            "type": "Stack",
            "props": { "direction": "horizontal", "align": "center", "spacing": 2 },
            "children": [
              {
                "type": "Heading",
                "props": { "level": 2, "children": "Pending Transfer Approvals" }
              },
              {
                "type": "Badge",
                "if": "{{data.pending_transfers.length > 0}}",
                "props": {
                  "variant": "destructive",
                  "children": "{{data.pending_transfers.length}} awaiting approval"
                }
              },
              {
                "type": "Badge",
                "if": "{{data.pending_transfers.length === 0}}",
                "props": {
                  "variant": "secondary",
                  "children": "None pending"
                }
              }
            ]
          },
          {
            "type": "Text",
            "props": {
              "size": "sm",
              "variant": "muted",
              "children": "Fleet-auditor findings that require your approval before a transfer order is created. Each finding explains the utilization or demand imbalance driving the suggestion."
            }
          },
          {
            "type": "Text",
            "if": "{{isLoading.pending_transfers}}",
            "props": { "variant": "muted", "children": "Loading pending approvals…" }
          },
          {
            "type": "Text",
            "if": "{{!isLoading.pending_transfers && data.pending_transfers.length === 0}}",
            "props": {
              "variant": "muted",
              "className": "py-4 text-center",
              "children": "No transfer findings pending approval."
            }
          },
          {
            "type": "Stack",
            "if": "{{data.pending_transfers.length > 0}}",
            "props": { "spacing": 3 },
            "children": [
              {
                "type": "Card",
                "each": "{{data.pending_transfers}}",
                "as": "finding",
                "key": "{{finding.id}}",
                "props": { "className": "border-amber-500" },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 2 },
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "weight": "semibold",
                              "children": "{{formatFindingType(finding.finding_type)}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "props": {
                              "status": "{{finding.status}}",
                              "children": "{{formatFindingStatus(finding.status)}}"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "children": "{{finding.rationale || 'No rationale provided.'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "{{finding.proposed_action || ''}}"
                        }
                      },
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "size": "sm",
                              "variant": "muted",
                              "children": "Confidence: {{formatPercent(finding.confidence)}} · Detected: {{formatDate(finding.created_at)}}"
                            }
                          },
                          {
                            "type": "Link",
                            "props": {
                              "to": "/ops/findings/{{finding.id}}",
                              "children": "Review & approve"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
