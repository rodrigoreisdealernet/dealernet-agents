{
  "id": "rental-availability",
  "title": "Branch Availability Lookup",
  "state": {},
  "dataSources": {
    "availability": {
      "type": "supabase",
      "table": "rental_asset_availability_current",
      "select": "*",
      "order": [
        { "column": "branch_name", "ascending": true },
        { "column": "asset_category_name", "ascending": true }
      ]
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "spacing": 1 },
        "children": [
          {
            "type": "Heading",
            "props": { "level": 1, "children": "Branch Availability Lookup" }
          },
          {
            "type": "Text",
            "props": {
              "variant": "muted",
              "children": "Browse available and unavailable fleet counts by branch and asset category."
            }
          },
          {
            "type": "Stack",
            "if": "{{params.branch_id}}",
            "props": { "direction": "horizontal", "align": "center", "spacing": 2 },
            "children": [
              {
                "type": "Badge",
                "props": { "variant": "secondary", "children": "branch scope" }
              },
              {
                "type": "Text",
                "props": {
                  "variant": "muted",
                  "size": "sm",
                  "children": "{{data.availability && data.availability.length > 0 ? data.availability[0].branch_name : 'selected branch'}}"
                }
              }
            ]
          },
          {
            "type": "Stack",
            "if": "{{params.category_id}}",
            "props": { "direction": "horizontal", "align": "center", "spacing": 2 },
            "children": [
              {
                "type": "Badge",
                "props": { "variant": "secondary", "children": "category scope" }
              },
              {
                "type": "Text",
                "props": {
                  "variant": "muted",
                  "size": "sm",
                  "children": "{{data.availability && data.availability.length > 0 ? data.availability[0].asset_category_name : 'selected category'}}"
                }
              }
            ]
          }
        ]
      },
      {
        "type": "Card",
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 3 },
            "children": [
              {
                "type": "Stack",
                "if": "{{!isLoading.availability && !errors.availability && data.availability && data.availability.length > 0}}",
                "each": "{{data.availability}}",
                "as": "row",
                "key": "{{row.branch_id}}-{{row.asset_category_id}}",
                "props": {
                  "spacing": 2,
                  "className": "border rounded-lg p-4"
                },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "weight": "semibold",
                          "children": "{{row.branch_name}} • {{row.asset_category_name}}"
                        }
                      },
                      {
                        "type": "Badge",
                        "props": {
                          "variant": "secondary",
                          "children": "{{row.available_assets}} available"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "variant": "muted",
                      "children": "{{row.unavailable_assets}} unavailable / {{row.total_assets}} total"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "variant": "muted",
                      "children": "Maintenance due: {{row.maintenance_due_assets}}"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "variant": "muted",
                      "children": "Maintenance overdue: {{row.maintenance_overdue_assets}}"
                    }
                  },
                  {
                    "type": "Stack",
                    "if": "{{row.soft_down_assets > 0 || row.hard_down_assets > 0}}",
                    "props": { "direction": "horizontal", "spacing": 2, "align": "center", "wrap": true },
                    "children": [
                      {
                        "type": "Badge",
                        "if": "{{row.hard_down_assets > 0}}",
                        "props": {
                          "variant": "destructive",
                          "children": "{{row.hard_down_assets}} hard-down"
                        }
                      },
                      {
                        "type": "Badge",
                        "if": "{{row.soft_down_assets > 0}}",
                        "props": {
                          "variant": "secondary",
                          "children": "{{row.soft_down_assets}} soft-down"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Link",
                    "props": {
                      "to": "/rental/orders?branch_id={{row.branch_id}}&category_id={{row.asset_category_id}}",
                      "children": "Create Rental Order"
                    }
                  }
                ]
              },
              {
                "type": "Text",
                "if": "{{isLoading.availability}}",
                "props": {
                  "variant": "muted",
                  "className": "text-center py-8",
                  "children": "Loading scoped availability..."
                }
              },
              {
                "type": "Text",
                "if": "{{errors.availability}}",
                "props": {
                  "variant": "muted",
                  "className": "text-center py-8",
                  "children": "Unable to load scoped availability. Please refresh and try again."
                }
              },
              {
                "type": "Text",
                "if": "{{!isLoading.availability && !errors.availability && data.availability && data.availability.length === 0}}",
                "props": {
                  "variant": "muted",
                  "className": "text-center py-8",
                  "children": "No branch availability data found."
                }
              },
              {
                "type": "Link",
                "if": "{{!isLoading.availability && !errors.availability && data.availability && data.availability.length === 0 && params.branch_id && params.category_id}}",
                "props": {
                  "to": "/rental/orders?branch_id={{params.branch_id}}&category_id={{params.category_id}}",
                  "children": "Create Rental Order"
                }
              },
              {
                "type": "Link",
                "if": "{{!isLoading.availability && !errors.availability && data.availability && data.availability.length === 0 && params.branch_id && !params.category_id}}",
                "props": {
                  "to": "/rental/orders?branch_id={{params.branch_id}}",
                  "children": "Create Rental Order"
                }
              },
              {
                "type": "Link",
                "if": "{{!isLoading.availability && !errors.availability && data.availability && data.availability.length === 0 && !params.branch_id && params.category_id}}",
                "props": {
                  "to": "/rental/orders?category_id={{params.category_id}}",
                  "children": "Create Rental Order"
                }
              },
              {
                "type": "Link",
                "if": "{{!isLoading.availability && !errors.availability && data.availability && data.availability.length === 0 && !params.branch_id && !params.category_id}}",
                "props": {
                  "to": "/rental/orders",
                  "children": "Create Rental Order"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
