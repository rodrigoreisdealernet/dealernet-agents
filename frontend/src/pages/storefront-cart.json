{
  "id": "storefront-cart",
  "title": "Rental Cart",
  "state": {
    "damageWaiverEnabled": false,
    "deliveryEnabled": false
  },
  "dataSources": {
    "asset": {
      "type": "supabase",
      "table": "entities",
      "select": "id, entity_type, created_at, entity_versions!inner(id, data, is_current)",
      "filters": [
        { "field": "id", "op": "eq", "value": "{{params.asset_id}}" },
        { "field": "entity_type", "op": "eq", "value": "asset" },
        { "field": "entity_versions.is_current", "op": "eq", "value": true }
      ],
      "single": true
    },
    "relatedAssets": {
      "type": "supabase",
      "table": "entities",
      "select": "id, entity_type, created_at, entity_versions!inner(id, data, is_current)",
      "filters": [
        { "field": "entity_type", "op": "eq", "value": "asset" },
        { "field": "entity_versions.is_current", "op": "eq", "value": true }
      ],
      "order": [{ "column": "created_at", "ascending": true }]
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "spacing": 1 },
        "children": [
          {
            "type": "Link",
            "props": {
              "to": "/rental/catalog",
              "children": "← Back to Catalog"
            }
          },
          {
            "type": "Heading",
            "props": { "level": 1, "children": "Your Rental Cart" }
          },
          {
            "type": "Text",
            "props": {
              "variant": "muted",
              "children": "Review your selection, choose add-ons, and submit your booking."
            }
          }
        ]
      },
      {
        "type": "Stack",
        "props": { "direction": "horizontal", "spacing": 6, "align": "start" },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 4, "className": "flex-1 min-w-0" },
            "children": [
              {
                "type": "Card",
                "props": { "className": "overflow-hidden" },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 0 },
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "spacing": 4, "align": "start", "className": "p-4" },
                        "children": [
                          {
                            "type": "Image",
                            "props": {
                              "src": "{{data.asset.entity_versions[0].data.image_url}}",
                              "alt": "{{data.asset.entity_versions[0].data.name}}",
                              "width": 120,
                              "height": 90,
                              "fallbackText": "{{data.asset.entity_versions[0].data.name}}",
                              "objectFit": "cover",
                              "className": "rounded-md shrink-0"
                            }
                          },
                          {
                            "type": "Stack",
                            "props": { "spacing": 2, "className": "flex-1" },
                            "children": [
                              {
                                "type": "Stack",
                                "props": { "direction": "horizontal", "justify": "between", "align": "start" },
                                "children": [
                                  {
                                    "type": "Text",
                                    "props": {
                                      "weight": "semibold",
                                      "size": "lg",
                                      "children": "{{data.asset.entity_versions[0].data.name}}"
                                    }
                                  },
                                  {
                                    "type": "Badge",
                                    "props": {
                                      "variant": "{{data.asset.entity_versions[0].data.status === 'available' ? 'default' : 'secondary'}}",
                                      "children": "{{data.asset.entity_versions[0].data.status}}"
                                    }
                                  }
                                ]
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "size": "sm",
                                  "variant": "muted",
                                  "children": "{{data.asset.entity_versions[0].data.make}} · {{data.asset.entity_versions[0].data.year}} · {{data.asset.entity_versions[0].data.identifier}}"
                                }
                              },
                              {
                                "type": "Stack",
                                "props": { "direction": "horizontal", "spacing": 6 },
                                "children": [
                                  {
                                    "type": "Stack",
                                    "props": { "spacing": 0 },
                                    "children": [
                                      {
                                        "type": "Text",
                                        "props": {
                                          "size": "xs",
                                          "variant": "muted",
                                          "children": "Start Date"
                                        }
                                      },
                                      {
                                        "type": "Text",
                                        "props": {
                                          "weight": "medium",
                                          "size": "sm",
                                          "children": "{{params.start_date || 'Not set'}}"
                                        }
                                      }
                                    ]
                                  },
                                  {
                                    "type": "Stack",
                                    "props": { "spacing": 0 },
                                    "children": [
                                      {
                                        "type": "Text",
                                        "props": {
                                          "size": "xs",
                                          "variant": "muted",
                                          "children": "End Date"
                                        }
                                      },
                                      {
                                        "type": "Text",
                                        "props": {
                                          "weight": "medium",
                                          "size": "sm",
                                          "children": "{{params.end_date || 'Not set'}}"
                                        }
                                      }
                                    ]
                                  },
                                  {
                                    "type": "Stack",
                                    "props": { "spacing": 0 },
                                    "children": [
                                      {
                                        "type": "Text",
                                        "props": {
                                          "size": "xs",
                                          "variant": "muted",
                                          "children": "Rental Days"
                                        }
                                      },
                                      {
                                        "type": "Text",
                                        "props": {
                                          "weight": "medium",
                                          "size": "sm",
                                          "children": "{{params.rental_days || '1'}} days"
                                        }
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Stack",
                "props": { "spacing": 3 },
                "children": [
                  {
                    "type": "Heading",
                    "props": { "level": 2, "children": "Add-Ons" }
                  },
                  {
                    "type": "Card",
                    "props": {},
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center", "className": "p-4" },
                        "children": [
                          {
                            "type": "Stack",
                            "props": { "spacing": 1 },
                            "children": [
                              {
                                "type": "Stack",
                                "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                                "children": [
                                  {
                                    "type": "Text",
                                    "props": { "weight": "semibold", "children": "Damage Waiver Protection" }
                                  },
                                  {
                                    "type": "Badge",
                                    "props": { "variant": "outline", "children": "Recommended" }
                                  }
                                ]
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "size": "sm",
                                  "variant": "muted",
                                  "children": "Covers accidental damage up to full replacement value. 12% of rental subtotal."
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "size": "sm",
                                  "weight": "medium",
                                  "children": "{{formatCurrency(computeDamageWaiverFee(computeRentalSubtotal(data.asset.entity_versions[0].data.daily_rate, data.asset.entity_versions[0].data.weekly_rate, data.asset.entity_versions[0].data.monthly_rate, params.rental_days || 1), true))}}"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Button",
                            "props": {
                              "variant": "{{state.damageWaiverEnabled ? 'default' : 'outline'}}",
                              "size": "sm",
                              "children": "{{state.damageWaiverEnabled ? 'Added ✓' : 'Add'}}",
                              "onClick": {
                                "action": "setState",
                                "key": "damageWaiverEnabled",
                                "value": "{{!state.damageWaiverEnabled}}"
                              }
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Card",
                    "props": {},
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center", "className": "p-4" },
                        "children": [
                          {
                            "type": "Stack",
                            "props": { "spacing": 1 },
                            "children": [
                              {
                                "type": "Text",
                                "props": { "weight": "semibold", "children": "Delivery & Pickup" }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "size": "sm",
                                  "variant": "muted",
                                  "children": "We deliver to your job site and pick up on the last day. Flat fee."
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "size": "sm",
                                  "weight": "medium",
                                  "children": "$150.00 flat"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Button",
                            "props": {
                              "variant": "{{state.deliveryEnabled ? 'default' : 'outline'}}",
                              "size": "sm",
                              "children": "{{state.deliveryEnabled ? 'Added ✓' : 'Add'}}",
                              "onClick": {
                                "action": "setState",
                                "key": "deliveryEnabled",
                                "value": "{{!state.deliveryEnabled}}"
                              }
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Stack",
                "if": "{{countCartCrossSellAssets(data.relatedAssets, data.asset.entity_versions[0].data.asset_category_id || data.asset.entity_versions[0].data.category_id, params.asset_id) > 0}}",
                "props": { "spacing": 3 },
                "children": [
                  {
                    "type": "Heading",
                    "props": { "level": 2, "children": "You Might Also Need" }
                  },
                  {
                    "type": "Grid",
                    "props": {
                      "columns": "repeat(auto-fill, minmax(14rem, 1fr))",
                      "gap": 3
                    },
                    "children": [
                      {
                        "type": "Card",
                        "each": "{{getCartCrossSellAssets(data.relatedAssets, data.asset.entity_versions[0].data.asset_category_id || data.asset.entity_versions[0].data.category_id, params.asset_id)}}",
                        "as": "related",
                        "key": "{{related.id}}",
                        "props": { "className": "overflow-hidden" },
                        "children": [
                          {
                            "type": "Stack",
                            "props": { "spacing": 0 },
                            "children": [
                              {
                                "type": "Image",
                                "props": {
                                  "src": "{{related.entity_versions[0].data.image_url}}",
                                  "alt": "{{related.entity_versions[0].data.name}}",
                                  "height": 120,
                                  "fallbackText": "{{related.entity_versions[0].data.name}}",
                                  "objectFit": "cover",
                                  "className": "rounded-none"
                                }
                              },
                              {
                                "type": "Stack",
                                "props": { "spacing": 2, "className": "p-3" },
                                "children": [
                                  {
                                    "type": "Text",
                                    "props": {
                                      "weight": "semibold",
                                      "size": "sm",
                                      "children": "{{related.entity_versions[0].data.name}}"
                                    }
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "size": "xs",
                                      "variant": "muted",
                                      "children": "${{related.entity_versions[0].data.daily_rate}}/day"
                                    }
                                  },
                                  {
                                    "type": "Link",
                                    "props": {
                                      "to": "/storefront/cart",
                                      "search": {
                                        "asset_id": "{{related.id}}",
                                        "start_date": "{{params.start_date}}",
                                        "end_date": "{{params.end_date}}",
                                        "rental_days": "{{params.rental_days}}"
                                      },
                                      "children": "Add to Cart →",
                                      "className": "text-xs font-medium text-primary hover:underline"
                                    }
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Stack",
            "props": { "spacing": 4, "className": "w-72 shrink-0" },
            "children": [
              {
                "type": "Card",
                "props": {},
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 3, "className": "p-4" },
                    "children": [
                      {
                        "type": "Heading",
                        "props": { "level": 3, "children": "Order Summary" }
                      },
                      {
                        "type": "Stack",
                        "props": { "spacing": 2 },
                        "children": [
                          {
                            "type": "Stack",
                            "props": { "direction": "horizontal", "justify": "between" },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "size": "sm",
                                  "children": "{{data.asset.entity_versions[0].data.name}} ({{params.rental_days || 1}} days)"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "size": "sm",
                                  "weight": "medium",
                                  "children": "{{formatCurrency(computeRentalSubtotal(data.asset.entity_versions[0].data.daily_rate, data.asset.entity_versions[0].data.weekly_rate, data.asset.entity_versions[0].data.monthly_rate, params.rental_days || 1))}}"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Stack",
                            "if": "{{state.damageWaiverEnabled}}",
                            "props": { "direction": "horizontal", "justify": "between" },
                            "children": [
                              {
                                "type": "Text",
                                "props": { "size": "sm", "children": "Damage Waiver" }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "size": "sm",
                                  "weight": "medium",
                                  "children": "{{formatCurrency(computeDamageWaiverFee(computeRentalSubtotal(data.asset.entity_versions[0].data.daily_rate, data.asset.entity_versions[0].data.weekly_rate, data.asset.entity_versions[0].data.monthly_rate, params.rental_days || 1), state.damageWaiverEnabled))}}"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Stack",
                            "if": "{{state.deliveryEnabled}}",
                            "props": { "direction": "horizontal", "justify": "between" },
                            "children": [
                              {
                                "type": "Text",
                                "props": { "size": "sm", "children": "Delivery & Pickup" }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "size": "sm",
                                  "weight": "medium",
                                  "children": "$150.00"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Stack",
                            "props": {
                              "direction": "horizontal",
                              "justify": "between",
                              "className": "border-t pt-2"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": { "weight": "semibold", "children": "Total" }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "weight": "bold",
                                  "children": "{{formatCurrency(computeCartTotal(data.asset.entity_versions[0].data.daily_rate, data.asset.entity_versions[0].data.weekly_rate, data.asset.entity_versions[0].data.monthly_rate, params.rental_days || 1, state.damageWaiverEnabled, state.deliveryEnabled))}}"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Button",
                "props": {
                  "className": "w-full",
                  "children": "Request Booking",
                  "onClick": {
                    "action": "apiCall",
                    "operation": "rpc",
                    "function": "create_entity_with_version",
                    "data": {
                      "p_entity_type": "rental_order",
                      "p_data": {
                        "status": "draft",
                        "rental_type": "external",
                        "lines": [
                          {
                            "asset_id": "{{params.asset_id}}",
                            "rental_days": "{{params.rental_days || 1}}",
                            "start_date": "{{params.start_date}}",
                            "end_date": "{{params.end_date}}"
                          }
                        ],
                        "add_ons": {
                          "damage_waiver": "{{state.damageWaiverEnabled}}",
                          "delivery": "{{state.deliveryEnabled}}"
                        },
                        "subtotal": "{{computeRentalSubtotal(data.asset.entity_versions[0].data.daily_rate, data.asset.entity_versions[0].data.weekly_rate, data.asset.entity_versions[0].data.monthly_rate, params.rental_days || 1)}}",
                        "total": "{{computeCartTotal(data.asset.entity_versions[0].data.daily_rate, data.asset.entity_versions[0].data.weekly_rate, data.asset.entity_versions[0].data.monthly_rate, params.rental_days || 1, state.damageWaiverEnabled, state.deliveryEnabled)}}"
                      }
                    },
                    "onSuccess": {
                      "action": "navigate",
                      "to": "/rental/orders"
                    }
                  }
                }
              },
              {
                "type": "Text",
                "props": {
                  "size": "xs",
                  "variant": "muted",
                  "className": "text-center",
                  "children": "No payment required now. A team member will confirm availability and contact you to finalize."
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
