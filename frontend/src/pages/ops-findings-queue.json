{
  "id": "ops-findings-queue",
  "title": "Audit History",
  "state": {
    "workflowFilter": "%",
    "severityFilter": "%",
    "statusFilter": "%",
    "branchFilter": "%",
    "customerFilter": "%"
  },
  "dataSources": {
    "findings": {
      "type": "supabase",
      "table": "ops_findings_view",
      "select": "id, agent_key, finding_type, severity, status, contract_label, line_item_label, customer_name, delta, confidence, created_at",
      "filters": [
        { "field": "agent_key", "op": "ilike", "value": "{{state.workflowFilter || '%'}}" },
        { "field": "severity", "op": "ilike", "value": "{{state.severityFilter || '%'}}" },
        { "field": "status", "op": "ilike", "value": "{{state.statusFilter || '%'}}" },
        { "field": "contract_label", "op": "ilike", "value": "{{state.branchFilter || '%'}}" },
        { "field": "customer_name", "op": "ilike", "value": "{{state.customerFilter || '%'}}" }
      ],
      "order": [
        { "column": "delta", "ascending": false },
        { "column": "created_at", "ascending": false }
      ],
      "refetchInterval": 10000
    },
    "agents": {
      "type": "supabase",
      "table": "ops_agent_status_view",
      "select": "agent_key",
      "order": [
        { "column": "agent_key", "ascending": true }
      ]
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "spacing": 1 },
        "children": [
          { "type": "Heading", "props": { "level": 1, "children": "Audit History" } },
          {
            "type": "Text",
            "props": {
              "variant": "muted",
              "children": "Review the full history of revenue and fleet findings, sorted by highest dollar impact first."
            }
          }
        ]
      },
      {
        "type": "Grid",
        "props": { "columns": "repeat(auto-fit, minmax(12rem, 1fr))", "gap": 3 },
        "children": [
          {
            "type": "Select",
            "props": {
              "label": "Workflow",
              "value": "{{state.workflowFilter}}",
              "options": [
                { "value": "%", "label": "All" },
                { "value": "credit-analyst", "label": "AR Collections" },
                { "value": "revrec-analyst", "label": "Revenue Recognition" },
                { "value": "fleet-auditor", "label": "Fleet Audits" },
                { "value": "damage-returns-charge-assistant", "label": "Damage & Returns Charges" },
                { "value": "quote-to-order-copilot", "label": "Quote-to-Order Copilot" }
              ],
              "onChange": {
                "action": "setState",
                "key": "workflowFilter",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Select",
            "props": {
              "label": "Severity",
              "value": "{{state.severityFilter}}",
              "options": [
                { "value": "%", "label": "All" },
                { "value": "critical", "label": "critical" },
                { "value": "high", "label": "high" },
                { "value": "medium", "label": "medium" },
                { "value": "low", "label": "low" }
              ],
              "onChange": {
                "action": "setState",
                "key": "severityFilter",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Select",
            "props": {
              "label": "Status",
              "value": "{{state.statusFilter}}",
              "options": [
                { "value": "%", "label": "All" },
                { "value": "pending_approval", "label": "pending_approval" },
                { "value": "approved", "label": "approved" },
                { "value": "rejected", "label": "rejected" },
                { "value": "informational", "label": "informational" }
              ],
              "onChange": {
                "action": "setState",
                "key": "statusFilter",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Input",
            "props": {
              "label": "Branch / Contract",
              "placeholder": "Use % for contains",
              "value": "{{state.branchFilter === '%' ? '' : state.branchFilter}}",
              "onChange": {
                "action": "setState",
                "key": "branchFilter",
                "value": "{{event.target.value || '%'}}"
              }
            }
          },
          {
            "type": "Input",
            "props": {
              "label": "Customer",
              "placeholder": "Use % for contains",
              "value": "{{state.customerFilter === '%' ? '' : state.customerFilter}}",
              "onChange": {
                "action": "setState",
                "key": "customerFilter",
                "value": "{{event.target.value || '%'}}"
              }
            }
          }
        ]
      },
      {
        "type": "Text",
        "if": "{{isLoading.findings}}",
        "props": {
          "variant": "muted",
          "children": "Loading findings..."
        }
      },
      {
        "type": "Alert",
        "if": "{{errors.findings}}",
        "props": {
          "variant": "destructive",
          "title": "Unable to load findings",
          "description": "Check filters or retry shortly."
        }
      },
      {
        "type": "Text",
        "if": "{{data.findings.length === 0}}",
        "props": {
          "variant": "muted",
          "className": "py-8 text-center",
          "children": "No findings match the selected filters."
        }
      },
      {
        "type": "Stack",
        "if": "{{data.findings.length > 0}}",
        "props": { "spacing": 3 },
        "children": [
          {
            "type": "Card",
            "each": "{{data.findings}}",
            "as": "finding",
            "key": "{{finding.id}}",
            "props": {
              "className": "{{finding.status === 'pending_approval' ? 'border-amber-500' : ''}}"
            },
            "children": [
              {
                "type": "Stack",
                "props": { "spacing": 2 },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "weight": "semibold",
                          "children": "{{finding.finding_type}}"
                        }
                      },
                      {
                        "type": "Badge",
                        "props": {
                          "variant": "{{finding.status === 'pending_approval' ? 'destructive' : 'secondary'}}",
                          "children": "{{finding.status}}"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "variant": "muted",
                      "children": "{{finding.severity}} · {{formatOpsAgentLabel(finding.agent_key)}}"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "children": "Contract: {{finding.contract_label || 'N/A'}} · Line: {{finding.line_item_label || 'N/A'}}"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "children": "Customer: {{finding.customer_name || 'N/A'}}"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "children": "Delta: {{formatCurrency(finding.delta || 0, finding.transaction_currency_code || finding.currency || data.reporting_currency_code || 'USD')}} · Confidence: {{finding.confidence || 0}}"
                    }
                  },
                  {
                    "type": "Stack",
                    "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "Detected: {{formatDate(finding.created_at)}}"
                        }
                      },
                      {
                        "type": "Link",
                        "props": {
                          "to": "/ops/findings/{{finding.id}}",
                          "children": "Open finding"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
