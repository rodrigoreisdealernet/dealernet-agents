{
  "id": "branch-ops-dashboard",
  "title": "Branch Operations Dashboard",
  "state": {},
  "dataSources": {
    "utilization": {
      "type": "supabase",
      "table": "v_branch_utilization",
      "select": "branch_id, branch_name, on_rent_count, utilization_rate_pct, last_updated",
      "order": [
        { "column": "branch_name", "ascending": true }
      ]
    },
    "in_flight": {
      "type": "supabase",
      "table": "v_current_assets",
      "select": "asset_id, name, serial_number, status, category_id",
      "filters": [
        { "field": "status", "op": "eq", "value": "on_transfer" }
      ],
      "order": [
        { "column": "name", "ascending": true }
      ]
    },
    "availability": {
      "type": "supabase",
      "table": "rental_asset_availability_current",
      "select": "*",
      "order": [
        { "column": "branch_name", "ascending": true },
        { "column": "asset_category_name", "ascending": true }
      ]
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "spacing": 1 },
        "children": [
          {
            "type": "Heading",
            "props": { "level": 1, "children": "Branch Operations Dashboard" }
          },
          {
            "type": "Text",
            "props": {
              "variant": "muted",
              "children": "Multi-location visibility: utilization, transfers in flight, and availability blockers."
            }
          }
        ]
      },
      {
        "type": "Card",
        "props": { "title": "Morning Brief" },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 3 },
            "children": [
              {
                "type": "Text",
                "props": {
                  "variant": "muted",
                  "children": "Ranked disposition-ready queue: contract & AP exceptions, dispatch risks, maintenance blockers, unavailable units, and customer follow-up prompts."
                }
              },
              {
                "type": "Link",
                "props": {
                  "to": "/branch/morning-brief",
                  "children": "Open Morning Brief →"
                }
              }
            ]
          }
        ]
      },
      {
        "type": "Card",
        "props": { "title": "Branch Performance" },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 3 },
            "children": [
              {
                "type": "Stack",
                "if": "{{data.utilization && data.utilization.length > 0}}",
                "each": "{{data.utilization}}",
                "as": "branch",
                "key": "{{branch.branch_id}}",
                "props": {
                  "spacing": 2,
                  "className": "border rounded-lg p-4"
                },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "weight": "semibold",
                          "children": "{{branch.branch_name}}"
                        }
                      },
                      {
                        "type": "Badge",
                        "props": {
                          "variant": "secondary",
                          "children": "{{branch.on_rent_count}} on rent"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "variant": "muted",
                      "children": "Utilization: {{branch.utilization_rate_pct}}%"
                    }
                  },
                  {
                    "type": "Link",
                    "props": {
                      "to": "/rental/availability?branch_id={{branch.branch_id}}",
                      "children": "Check Availability"
                    }
                  }
                ]
              },
              {
                "type": "Text",
                "if": "{{!data.utilization || data.utilization.length === 0}}",
                "props": {
                  "variant": "muted",
                  "className": "text-center py-8",
                  "children": "No branch utilization data found."
                }
              },
              {
                "type": "Link",
                "props": {
                  "to": "/rental/availability",
                  "children": "View Full Availability"
                }
              }
            ]
          }
        ]
      },
      {
        "type": "Card",
        "props": { "title": "Transfers In Flight" },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 3 },
            "children": [
              {
                "type": "Stack",
                "if": "{{data.in_flight && data.in_flight.length > 0}}",
                "each": "{{data.in_flight}}",
                "as": "asset",
                "key": "{{asset.asset_id}}",
                "props": {
                  "spacing": 1,
                  "className": "border rounded-lg p-4"
                },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "weight": "semibold",
                          "children": "{{asset.name}}"
                        }
                      },
                      {
                        "type": "Badge",
                        "props": {
                          "variant": "outline",
                          "children": "In Transit"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "variant": "muted",
                      "children": "Serial: {{asset.serial_number}}"
                    }
                  },
                  {
                    "type": "Link",
                    "props": {
                      "to": "/rental/returns?asset_id={{asset.asset_id}}",
                      "children": "Check In Asset"
                    }
                  }
                ]
              },
              {
                "type": "Text",
                "if": "{{!data.in_flight || data.in_flight.length === 0}}",
                "props": {
                  "variant": "muted",
                  "className": "text-center py-8",
                  "children": "No transfers currently in flight."
                }
              },
              {
                "type": "Link",
                "props": {
                  "to": "/rental/returns",
                  "children": "Open Returns / Check-In"
                }
              }
            ]
          }
        ]
      },
      {
        "type": "Card",
        "props": { "title": "Availability & Operational Blockers" },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 3 },
            "children": [
              {
                "type": "Stack",
                "if": "{{data.availability && data.availability.length > 0}}",
                "each": "{{data.availability}}",
                "as": "row",
                "key": "{{row.branch_id}}-{{row.asset_category_id}}",
                "props": {
                  "spacing": 2,
                  "className": "border rounded-lg p-4"
                },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "weight": "semibold",
                          "children": "{{row.branch_name}} • {{row.asset_category_name}}"
                        }
                      },
                      {
                        "type": "Badge",
                        "props": {
                          "variant": "secondary",
                          "children": "{{row.available_assets}} available"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "variant": "muted",
                      "children": "{{row.unavailable_assets}} unavailable / {{row.total_assets}} total"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "variant": "muted",
                      "children": "Maintenance overdue: {{row.maintenance_overdue_assets}}"
                    }
                  },
                  {
                    "type": "Link",
                    "props": {
                      "to": "/rental/availability?branch_id={{row.branch_id}}&category_id={{row.asset_category_id}}",
                      "children": "Check Availability"
                    }
                  }
                ]
              },
              {
                "type": "Text",
                "if": "{{!data.availability || data.availability.length === 0}}",
                "props": {
                  "variant": "muted",
                  "className": "text-center py-8",
                  "children": "No availability data found."
                }
              },
              {
                "type": "Link",
                "props": {
                  "to": "/rental/availability",
                  "children": "View Full Availability"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
