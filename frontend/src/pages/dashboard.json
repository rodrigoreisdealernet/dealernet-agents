{
  "id": "dashboard",
  "title": "Operations Dashboard",
  "state": {},
  "dataSources": {
    "kpis": {
      "type": "supabase",
      "table": "v_home_dashboard_kpis",
      "select": "as_of, assets_on_rent, fleet_utilization_pct, overdue_returns_count, open_maintenance_count, period_revenue, prior_period_revenue, available_assets, unavailable_assets, total_assets",
      "single": true
    },
    "ops_agents": {
      "type": "supabase",
      "table": "ops_agent_status_view",
      "select": "agent_key, enabled, last_run_status, last_run_finished_at, pending_findings, identified_delta",
      "order": [
        { "column": "pending_findings", "ascending": false },
        { "column": "agent_key", "ascending": true }
      ],
      "refetchInterval": 15000
    },
    "ops_kpis": {
      "type": "supabase",
      "table": "ops_finding_kpis",
      "select": "pending_count, recoverable_delta, approved_this_cycle, findings_last_24h",
      "limit": 1,
      "refetchInterval": 15000
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "direction": "horizontal", "justify": "between", "align": "start" },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 1 },
            "children": [
              {
                "type": "Heading",
                "props": { "level": 2, "children": "Operations Dashboard" }
              },
              {
                "type": "Text",
                "props": {
                  "variant": "muted",
                  "children": "Live operational KPIs from Supabase with direct links to act."
                }
              }
            ]
          },
          {
            "type": "Text",
            "if": "{{data.kpis && data.kpis.as_of}}",
            "props": {
              "size": "sm",
              "variant": "muted",
              "className": "rounded-full bg-muted px-3 py-1 tabular-nums whitespace-nowrap",
              "children": "As of {{formatDateTime(data.kpis.as_of)}}"
            }
          }
        ]
      },
      {
        "type": "Grid",
        "props": { "columns": "repeat(auto-fit, minmax(15rem, 1fr))", "gap": 4 },
        "children": [
          {
            "type": "StatCard",
            "props": {
              "label": "Assets on Rent",
              "value": "{{data.kpis.assets_on_rent || 0}}",
              "hint": "{{data.kpis.fleet_utilization_pct || 0}}% of {{data.kpis.total_assets || 0}} assets",
              "icon": "Truck",
              "to": "/branch/ops",
              "linkLabel": "Branch Operations"
            }
          },
          {
            "type": "StatCard",
            "props": {
              "label": "Overdue Returns",
              "value": "{{data.kpis.overdue_returns_count || 0}}",
              "icon": "Undo2",
              "tone": "{{data.kpis.overdue_returns_count > 0 ? 'danger' : 'success'}}",
              "delta": {
                "direction": "{{data.kpis.overdue_returns_count > 0 ? 'up' : 'flat'}}",
                "label": "{{data.kpis.overdue_returns_count > 0 ? 'overdue' : 'All clear'}}"
              },
              "to": "/rental/returns",
              "linkLabel": "Returns"
            }
          },
          {
            "type": "StatCard",
            "props": {
              "label": "Open Maintenance",
              "value": "{{data.kpis.open_maintenance_count || 0}}",
              "icon": "Wrench",
              "tone": "{{data.kpis.open_maintenance_count > 0 ? 'warning' : 'default'}}",
              "to": "/entities/maintenance_record",
              "linkLabel": "Maintenance Queue"
            }
          },
          {
            "type": "StatCard",
            "props": {
              "label": "Period Revenue",
              "value": "{{formatCurrency(data.kpis.period_revenue || 0)}}",
              "icon": "CircleDollarSign",
              "delta": {
                "direction": "{{data.kpis.period_revenue > data.kpis.prior_period_revenue ? 'up' : data.kpis.period_revenue < data.kpis.prior_period_revenue ? 'down' : 'flat'}}",
                "label": "vs prior period"
              },
              "to": "/analytics/fleet",
              "linkLabel": "Fleet Reporting"
            }
          },
          {
            "type": "StatCard",
            "props": {
              "label": "Availability Snapshot",
              "value": "{{data.kpis.available_assets || 0}}",
              "hint": "{{data.kpis.available_assets || 0}} available · {{data.kpis.unavailable_assets || 0}} unavailable",
              "icon": "Package",
              "to": "/rental/availability",
              "linkLabel": "Availability Lookup"
            }
          }
        ]
      },
      {
        "type": "Card",
        "props": { "title": "Agentic Operations" },
        "children": [
          {
            "type": "Grid",
            "if": "{{data.ops_kpis && data.ops_kpis.length > 0}}",
            "props": {
              "columns": "repeat(auto-fit, minmax(9rem, 1fr))",
              "gap": 4,
              "className": "mb-6 rounded-md bg-muted/40 p-4"
            },
            "children": [
              {
                "type": "Stack",
                "props": { "spacing": 1 },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "size": "xs",
                      "variant": "muted",
                      "className": "uppercase tracking-wide",
                      "children": "Pending Findings"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "weight": "semibold",
                      "size": "lg",
                      "className": "tabular-nums",
                      "children": "{{data.ops_kpis[0].pending_count || 0}}"
                    }
                  }
                ]
              },
              {
                "type": "Stack",
                "props": { "spacing": 1 },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "size": "xs",
                      "variant": "muted",
                      "className": "uppercase tracking-wide",
                      "children": "Recoverable $"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "weight": "semibold",
                      "size": "lg",
                      "className": "tabular-nums",
                      "children": "{{formatCurrency(data.ops_kpis[0].recoverable_delta || 0)}}"
                    }
                  }
                ]
              },
              {
                "type": "Stack",
                "props": { "spacing": 1 },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "size": "xs",
                      "variant": "muted",
                      "className": "uppercase tracking-wide",
                      "children": "Approved This Cycle"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "weight": "semibold",
                      "size": "lg",
                      "className": "tabular-nums",
                      "children": "{{data.ops_kpis[0].approved_this_cycle || 0}}"
                    }
                  }
                ]
              },
              {
                "type": "Stack",
                "props": { "spacing": 1 },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "size": "xs",
                      "variant": "muted",
                      "className": "uppercase tracking-wide",
                      "children": "Findings (24h)"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "weight": "semibold",
                      "size": "lg",
                      "className": "tabular-nums",
                      "children": "{{data.ops_kpis[0].findings_last_24h || 0}}"
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "EmptyState",
            "if": "{{!data.ops_agents || data.ops_agents.length === 0}}",
            "props": {
              "icon": "Bot",
              "title": "No agents configured",
              "hint": "Agentic operations workflows will appear here once configured for this tenant."
            }
          },
          {
            "type": "Stack",
            "if": "{{data.ops_agents && data.ops_agents.length > 0}}",
            "props": { "spacing": 2 },
            "children": [
              {
                "type": "Stack",
                "each": "{{data.ops_agents}}",
                "as": "agent",
                "key": "{{agent.agent_key}}",
                "props": {
                  "direction": "horizontal",
                  "align": "center",
                  "justify": "between",
                  "spacing": 3,
                  "className": "rounded-md border px-4 py-3"
                },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 1 },
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                        "children": [
                          {
                            "type": "Badge",
                            "props": {
                              "variant": "{{agent.enabled ? (agent.last_run_status === 'failed' ? 'destructive' : 'secondary') : 'outline'}}",
                              "children": "{{agent.enabled ? (agent.last_run_status || 'not run') : 'disabled'}}"
                            }
                          },
                          {
                            "type": "Text",
                            "props": {
                              "weight": "semibold",
                              "children": "{{formatOpsAgentLabel(agent.agent_key)}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "if": "{{agent.pending_findings > 0}}",
                            "props": {
                              "variant": "destructive",
                              "children": "{{agent.pending_findings}} pending"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "last run {{formatDateTime(agent.last_run_finished_at)}}"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Stack",
                    "props": { "direction": "horizontal", "spacing": 4, "align": "center" },
                    "children": [
                      {
                        "type": "Text",
                        "if": "{{agent.identified_delta}}",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "className": "tabular-nums",
                          "children": "{{formatCurrency(agent.identified_delta)}}"
                        }
                      },
                      {
                        "type": "Link",
                        "props": {
                          "to": "/ops/findings?workflow={{agent.agent_key}}",
                          "appearance": "action",
                          "children": "Review queue"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Stack",
            "props": {
              "direction": "horizontal",
              "justify": "end",
              "className": "mt-2 border-t pt-4"
            },
            "children": [
              {
                "type": "Link",
                "props": {
                  "to": "/ops",
                  "appearance": "action",
                  "children": "Open Operations Dashboard"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
