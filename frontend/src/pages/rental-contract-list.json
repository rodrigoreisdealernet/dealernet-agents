{
  "id": "rental-contract-list",
  "title": "Rental Contracts",
  "dataSources": {
    "contracts": {
      "type": "supabase",
      "table": "entities",
      "select": "id, entity_type, created_at, entity_versions!inner(id, data, is_current, version_number)",
      "filters": [
        { "field": "entity_type", "op": "eq", "value": "rental_contract" },
        { "field": "entity_versions.is_current", "op": "eq", "value": true }
      ],
      "order": [{ "column": "created_at", "ascending": false }]
    },
    "orders": {
      "type": "supabase",
      "table": "entities",
      "select": "id, entity_versions!inner(data, is_current)",
      "filters": [
        { "field": "entity_type", "op": "eq", "value": "rental_order" },
        { "field": "entity_versions.is_current", "op": "eq", "value": true }
      ],
      "order": [{ "column": "created_at", "ascending": false }]
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 1 },
            "children": [
              {
                "type": "Heading",
                "props": { "level": 1, "children": "Rental Contracts" }
              },
              {
                "type": "Text",
                "props": { "variant": "muted", "children": "View and manage active contracts and their line items" }
              }
            ]
          }
        ]
      },
      {
        "type": "Card",
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 4 },
            "children": [
              {
                "type": "Heading",
                "props": { "level": 3, "children": "Contracts" }
              },
              {
                "type": "Stack",
                "props": { "spacing": 2 },
                "children": [
                  {
                    "type": "Stack",
                    "each": "{{data.contracts}}",
                    "as": "contract",
                    "key": "{{contract.id}}",
                    "props": {
                      "direction": "horizontal",
                      "justify": "between",
                      "align": "center",
                      "className": "p-4 border rounded-lg hover:bg-muted/50 cursor-pointer"
                    },
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "spacing": 1 },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "weight": "medium",
                              "children": "{{contract.entity_versions[0].data.contract_number || 'Rental Contract'}}"
                            }
                          },
                          {
                            "type": "Stack",
                            "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                            "children": [
                              {
                                "type": "Badge",
                                "props": {
                                  "status": "{{contract.entity_versions[0].data.status || 'pending_execution'}}",
                                  "children": "{{contract.entity_versions[0].data.status || 'pending_execution'}}"
                                }
                              },
                              {
                                "type": "Badge",
                                "props": {
                                  "status": "{{contract.entity_versions[0].data.rental_type || 'external'}}",
                                  "children": "{{contract.entity_versions[0].data.rental_type || 'external'}}"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "variant": "muted",
                              "size": "sm",
                              "children": "Order: {{contract.entity_versions[0].data.order_id ? lookupRecordFieldById(data.orders, contract.entity_versions[0].data.order_id, 'entity_versions[0].data.order_number', 'id') || lookupRecordFieldById(data.orders, contract.entity_versions[0].data.order_id, 'entity_versions[0].data.requester_name', 'id') || lookupRecordFieldById(data.orders, contract.entity_versions[0].data.order_id, 'entity_versions[0].data.requester_email', 'id') || 'Draft Order' : 'No linked order'}}"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Link",
                        "props": {
                          "to": "/rental/contracts/{{contract.id}}",
                          "appearance": "action",
                          "children": "View"
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "EmptyState",
                "if": "{{!data.contracts || data.contracts.length === 0}}",
                "props": {
                  "icon": "FileText",
                  "title": "No contracts yet",
                  "hint": "Contracts are created when rental orders are approved and converted.",
                  "to": "/rental/orders",
                  "linkLabel": "View rental orders"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
