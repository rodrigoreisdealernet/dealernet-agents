{
  "id": "ops-incident-compliance-queue",
  "title": "Incident Reporting & Compliance Queue",
  "state": {
    "obligationFilter": "%",
    "statusFilter": "pending_approval"
  },
  "dataSources": {
    "findings": {
      "type": "supabase",
      "table": "ops_findings_view",
      "select": "id, agent_key, contract_id, contract_label, line_item_id, line_item_label, customer_name, finding_type, severity, status, expected, evidence, proposed_action, confidence, rationale, created_at",
      "filters": [
        { "field": "agent_key", "op": "eq", "value": "incident-compliance-queue" },
        { "field": "finding_type", "op": "ilike", "value": "{{state.obligationFilter || '%'}}" },
        { "field": "status", "op": "ilike", "value": "{{state.statusFilter || '%'}}" }
      ],
      "order": [
        { "column": "created_at", "ascending": false }
      ],
      "refetchInterval": 15000
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "spacing": 1 },
        "children": [
          {
            "type": "Heading",
            "props": { "level": 1, "children": "Incident Reporting & Compliance Queue" }
          },
          {
            "type": "Text",
            "props": {
              "variant": "muted",
              "children": "One scoped incident-response queue for OSHA log follow-up, reportable-event deadlines, and post-accident testing obligations. The system proposes the next action, but recordable/reportable decisions and other employee-impacting actions remain pending explicit human disposition."
            }
          }
        ]
      },
      {
        "type": "Grid",
        "props": { "columns": "repeat(auto-fit, minmax(12rem, 1fr))", "gap": 3 },
        "children": [
          {
            "type": "Select",
            "props": {
              "label": "Obligation",
              "value": "{{state.obligationFilter}}",
              "options": [
                { "value": "%", "label": "All obligations" },
                { "value": "osha_log_follow_up", "label": "OSHA log follow-up" },
                { "value": "reportable_event_deadline", "label": "Reportable-event deadline" },
                { "value": "post_accident_testing", "label": "Post-accident testing" }
              ],
              "onChange": {
                "action": "setState",
                "key": "obligationFilter",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Select",
            "props": {
              "label": "Status",
              "value": "{{state.statusFilter}}",
              "options": [
                { "value": "%", "label": "All statuses" },
                { "value": "pending_approval", "label": "Pending approval" },
                { "value": "approved", "label": "Approved" },
                { "value": "rejected", "label": "Rejected" },
                { "value": "informational", "label": "Informational" }
              ],
              "onChange": {
                "action": "setState",
                "key": "statusFilter",
                "value": "{{event.target.value}}"
              }
            }
          }
        ]
      },
      {
        "type": "Text",
        "if": "{{isLoading.findings}}",
        "props": {
          "variant": "muted",
          "children": "Loading incident-response queue..."
        }
      },
      {
        "type": "Alert",
        "if": "{{errors.findings}}",
        "props": {
          "variant": "destructive",
          "title": "Unable to load incident-response queue",
          "description": "Retry shortly or review the latest workflow run before treating the queue as complete."
        }
      },
      {
        "type": "Alert",
        "if": "{{!isLoading.findings && !errors.findings && data.findings.length === 0}}",
        "props": {
          "variant": "info",
          "title": "No queued incident-response cases",
          "description": "Fail closed: confirm the latest incident workflow run completed and verify there are no missing intake records before treating this queue as clear."
        }
      },
      {
        "type": "Stack",
        "if": "{{data.findings.length > 0}}",
        "props": { "spacing": 3 },
        "children": [
          {
            "type": "Card",
            "each": "{{data.findings}}",
            "as": "finding",
            "key": "{{finding.id}}",
            "props": {
              "className": "{{finding.severity === 'critical' ? 'border-red-500' : finding.severity === 'high' ? 'border-amber-500' : ''}}"
            },
            "children": [
              {
                "type": "Stack",
                "props": { "spacing": 3 },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "weight": "semibold",
                          "children": "{{finding.expected && finding.expected.case_title ? finding.expected.case_title : formatFindingType(finding.finding_type)}}"
                        }
                      },
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                        "children": [
                          {
                            "type": "Badge",
                            "props": {
                              "variant": "{{finding.severity === 'critical' ? 'destructive' : 'secondary'}}",
                              "children": "{{finding.severity}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "props": {
                              "variant": "outline",
                              "children": "{{formatFindingType(finding.finding_type)}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "props": {
                              "variant": "{{finding.status === 'pending_approval' ? 'destructive' : 'secondary'}}",
                              "children": "{{formatFindingStatus(finding.status)}}"
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Grid",
                    "props": { "columns": "repeat(auto-fit, minmax(14rem, 1fr))", "gap": 3 },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "children": "Branch: {{finding.expected && finding.expected.branch_name ? finding.expected.branch_name : 'Missing branch context — blocked'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "children": "Employee: {{finding.expected && finding.expected.employee_name ? finding.expected.employee_name : 'Missing employee context — blocked'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "children": "Equipment: {{finding.expected && finding.expected.equipment_name ? finding.expected.equipment_name : finding.line_item_label || finding.contract_label || 'Missing equipment context — blocked'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "children": "Due time: {{finding.expected && finding.expected.due_at ? formatDate(finding.expected.due_at) : 'Missing deadline — blocked'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "children": "Cited rule: {{finding.expected && finding.expected.rule_citation ? finding.expected.rule_citation : 'Missing rule citation — blocked'}}"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "size": "sm",
                      "children": "Next action: {{finding.proposed_action || 'Needs human review'}}"
                    }
                  },
                  {
                    "type": "Alert",
                    "props": {
                      "variant": "warning",
                      "title": "Human disposition required",
                      "description": "Recordable/reportable determinations, employee-impacting actions, and hold or escalation decisions remain blocked until a reviewer explicitly approves or rejects this case."
                    }
                  },
                  {
                    "type": "Alert",
                    "if": "{{finding.expected && finding.expected.blockers && finding.expected.blockers.length > 0}}",
                    "props": {
                      "variant": "destructive",
                      "title": "Compliance blocker — needs human review",
                      "description": "{{finding.expected.blockers[0]}}"
                    }
                  },
                  {
                    "type": "Alert",
                    "if": "{{finding.expected && finding.expected.conflicting_evidence && finding.expected.conflicting_evidence.length > 0}}",
                    "props": {
                      "variant": "destructive",
                      "title": "Conflicting evidence — needs human review",
                      "description": "{{finding.expected.conflicting_evidence[0]}}"
                    }
                  },
                  {
                    "type": "Alert",
                    "if": "{{finding.expected && finding.expected.is_stale_data}}",
                    "props": {
                      "variant": "warning",
                      "title": "Stale evidence — verify before acting",
                      "description": "{{finding.expected.stale_signals && finding.expected.stale_signals.length > 0 ? finding.expected.stale_signals[0] : 'Evidence is stale.'}}"
                    }
                  },
                  {
                    "type": "Alert",
                    "if": "{{!finding.evidence || finding.evidence.length === 0}}",
                    "props": {
                      "variant": "destructive",
                      "title": "Missing evidence bundle",
                      "description": "Required evidence is missing, so this case must stay in human review."
                    }
                  },
                  {
                    "type": "Alert",
                    "if": "{{!(finding.expected && finding.expected.due_at)}}",
                    "props": {
                      "variant": "destructive",
                      "title": "Missing compliance deadline",
                      "description": "Required deadline evidence is missing, so this case cannot be treated as clear."
                    }
                  },
                  {
                    "type": "Alert",
                    "if": "{{!(finding.expected && finding.expected.rule_citation)}}",
                    "props": {
                      "variant": "destructive",
                      "title": "Missing rule citation",
                      "description": "Required rule citation is missing, so this case must stay in human review."
                    }
                  },
                  {
                    "type": "Stack",
                    "if": "{{finding.evidence && finding.evidence.length > 0}}",
                    "props": { "spacing": 2 },
                    "children": [
                      {
                        "type": "Text",
                        "props": { "size": "sm", "weight": "medium", "children": "Linked evidence" }
                      },
                      {
                        "type": "Stack",
                        "each": "{{finding.evidence}}",
                        "as": "evidence",
                        "key": "{{index}}",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center", "className": "rounded border p-2" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "size": "sm",
                              "children": "{{evidence.label || evidence.summary || evidence.description || evidence.event_type || evidence.type || ('Evidence item ' + (index + 1))}}"
                            }
                          },
                          {
                            "type": "Link",
                            "if": "{{evidence.entity_id || finding.contract_id}}",
                            "props": {
                              "to": "/ops/audit/{{evidence.entity_id || finding.contract_id}}",
                              "children": "Audit"
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Stack",
                    "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "{{finding.rationale || 'No rationale provided.'}}"
                        }
                      },
                      {
                        "type": "Link",
                        "props": {
                          "to": "/ops/findings/{{finding.id}}",
                          "search": {
                            "source": "incident-compliance-queue",
                            "returnObligation": "{{state.obligationFilter || '%'}}",
                            "returnStatus": "{{state.statusFilter || 'pending_approval'}}"
                          },
                          "children": "Open case"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
