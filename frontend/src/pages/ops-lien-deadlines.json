{
  "id": "ops-lien-deadlines",
  "title": "Lien Deadline & Waiver Control",
  "state": {
    "activeTab": "deadlines",
    "urgencyFilter": "%",
    "statusFilter": "%",
    "waiverStatusFilter": "%"
  },
  "dataSources": {
    "deadlines": {
      "type": "supabase",
      "table": "ops_findings_view",
      "select": "id, agent_key, finding_type, severity, status, expected, billed, delta, confidence, proposed_action, rationale, created_at",
      "filters": [
        { "field": "agent_key", "op": "eq", "value": "credit-lien-control" },
        { "field": "finding_type", "op": "eq", "value": "lien_deadline" },
        { "field": "status", "op": "ilike", "value": "{{state.statusFilter || '%'}}" }
      ],
      "order": [
        { "column": "delta", "ascending": true },
        { "column": "created_at", "ascending": false }
      ],
      "refetchInterval": 10000
    },
    "waivers": {
      "type": "supabase",
      "table": "ops_findings_view",
      "select": "id, agent_key, finding_type, severity, status, expected, billed, delta, confidence, proposed_action, rationale, created_at",
      "filters": [
        { "field": "agent_key", "op": "eq", "value": "credit-lien-control" },
        { "field": "finding_type", "op": "eq", "value": "lien_waiver" },
        { "field": "status", "op": "ilike", "value": "{{state.waiverStatusFilter || '%'}}" }
      ],
      "order": [
        { "column": "delta", "ascending": false },
        { "column": "created_at", "ascending": false }
      ],
      "refetchInterval": 10000
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "spacing": 1 },
        "children": [
          { "type": "Heading", "props": { "level": 1, "children": "Lien Deadline & Waiver Control" } },
          {
            "type": "Text",
            "props": {
              "variant": "muted",
              "children": "Monitor state-specific preliminary-notice deadlines and lien-waiver obligations. Deadlines are calculated deterministically from first-furnishing dates. All notice sends and waiver closeouts require analyst approval."
            }
          }
        ]
      },
      {
        "type": "Stack",
        "props": { "direction": "horizontal", "spacing": 2 },
        "children": [
          {
            "type": "Button",
            "props": {
              "variant": "{{state.activeTab === 'deadlines' ? 'default' : 'outline'}}",
              "children": "Preliminary Notices",
              "onClick": { "action": "setState", "key": "activeTab", "value": "deadlines" }
            }
          },
          {
            "type": "Button",
            "props": {
              "variant": "{{state.activeTab === 'waivers' ? 'default' : 'outline'}}",
              "children": "Lien Waivers",
              "onClick": { "action": "setState", "key": "activeTab", "value": "waivers" }
            }
          }
        ]
      },
      {
        "type": "Stack",
        "if": "{{state.activeTab === 'deadlines'}}",
        "props": { "spacing": 4 },
        "children": [
          {
            "type": "Grid",
            "props": { "columns": "repeat(auto-fit, minmax(12rem, 1fr))", "gap": 3 },
            "children": [
              {
                "type": "Select",
                "props": {
                  "label": "Status",
                  "value": "{{state.statusFilter}}",
                  "options": [
                    { "value": "%", "label": "All" },
                    { "value": "pending_approval", "label": "Pending approval" },
                    { "value": "approved", "label": "Approved" },
                    { "value": "rejected", "label": "Rejected" }
                  ],
                  "onChange": {
                    "action": "setState",
                    "key": "statusFilter",
                    "value": "{{event.target.value}}"
                  }
                }
              }
            ]
          },
          {
            "type": "Text",
            "if": "{{isLoading.deadlines}}",
            "props": { "variant": "muted", "children": "Loading lien deadlines..." }
          },
          {
            "type": "Alert",
            "if": "{{errors.deadlines}}",
            "props": {
              "variant": "destructive",
              "title": "Unable to load lien deadlines",
              "description": "Retry shortly or review the latest workflow run."
            }
          },
          {
            "type": "Text",
            "if": "{{data.deadlines.length === 0}}",
            "props": {
              "variant": "muted",
              "className": "py-8 text-center",
              "children": "No preliminary-notice obligations are surfaced. The deadline calendar is up to date."
            }
          },
          {
            "type": "Stack",
            "if": "{{data.deadlines.length > 0}}",
            "props": { "spacing": 3 },
            "children": [
              {
                "type": "Card",
                "each": "{{data.deadlines}}",
                "as": "finding",
                "key": "{{finding.id}}",
                "props": {
                  "className": "{{getUrgencyBorderClass(finding.expected.urgency)}}"
                },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 2 },
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "weight": "semibold",
                              "children": "{{finding.expected.project_name || finding.expected.project_id || 'Project obligation'}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "props": {
                              "variant": "{{finding.status === 'pending_approval' ? 'destructive' : 'secondary'}}",
                              "children": "{{formatFindingStatus(finding.status)}}"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "{{finding.expected.state || 'Unknown state'}} · Urgency: {{formatLienUrgency(finding.expected.urgency)}} · {{formatFindingType(finding.finding_type)}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "children": "Customer: {{finding.expected.customer_name || 'N/A'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "children": "Deadline: {{finding.expected.deadline_date || 'Not calculated'}} · Days remaining: {{finding.expected.days_remaining !== null ? finding.expected.days_remaining : 'N/A'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "children": "Notice sent: {{finding.expected.notice_sent ? 'Yes' : 'No'}} · Recommended: {{finding.proposed_action}}"
                        }
                      },
                      {
                        "type": "Text",
                        "if": "{{finding.expected.stale_inputs && finding.expected.stale_inputs.length > 0}}",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "Uncertainty: {{finding.expected.stale_inputs[0]}}"
                        }
                      },
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "size": "sm",
                              "variant": "muted",
                              "children": "{{finding.rationale || 'No rationale provided.'}}"
                            }
                          },
                          {
                            "type": "Link",
                            "props": {
                              "to": "/ops/findings/{{finding.id}}",
                              "search": {
                                "source": "lien-deadlines",
                                "returnStatus": "{{state.statusFilter}}"
                              },
                              "children": "Open finding"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Stack",
        "if": "{{state.activeTab === 'waivers'}}",
        "props": { "spacing": 4 },
        "children": [
          {
            "type": "Grid",
            "props": { "columns": "repeat(auto-fit, minmax(12rem, 1fr))", "gap": 3 },
            "children": [
              {
                "type": "Select",
                "props": {
                  "label": "Status",
                  "value": "{{state.waiverStatusFilter}}",
                  "options": [
                    { "value": "%", "label": "All" },
                    { "value": "pending_approval", "label": "Pending approval" },
                    { "value": "approved", "label": "Approved" },
                    { "value": "rejected", "label": "Rejected" }
                  ],
                  "onChange": {
                    "action": "setState",
                    "key": "waiverStatusFilter",
                    "value": "{{event.target.value}}"
                  }
                }
              }
            ]
          },
          {
            "type": "Text",
            "if": "{{isLoading.waivers}}",
            "props": { "variant": "muted", "children": "Loading lien waivers..." }
          },
          {
            "type": "Alert",
            "if": "{{errors.waivers}}",
            "props": {
              "variant": "destructive",
              "title": "Unable to load lien waivers",
              "description": "Retry shortly or review the latest workflow run."
            }
          },
          {
            "type": "Text",
            "if": "{{data.waivers.length === 0}}",
            "props": {
              "variant": "muted",
              "className": "py-8 text-center",
              "children": "No lien waivers are awaiting review. Waiver obligations are up to date."
            }
          },
          {
            "type": "Stack",
            "if": "{{data.waivers.length > 0}}",
            "props": { "spacing": 3 },
            "children": [
              {
                "type": "Card",
                "each": "{{data.waivers}}",
                "as": "finding",
                "key": "{{finding.id}}",
                "props": {
                  "className": "{{finding.status === 'pending_approval' ? 'border-amber-500' : ''}}"
                },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 2 },
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "weight": "semibold",
                              "children": "{{finding.expected.customer_name || 'Waiver obligation'}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "props": {
                              "variant": "{{finding.status === 'pending_approval' ? 'destructive' : 'secondary'}}",
                              "children": "{{formatFindingStatus(finding.status)}}"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "{{finding.severity}} · {{formatFindingType(finding.finding_type)}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "children": "Payment: {{formatCurrency(finding.billed.amount || 0)}} · Waiver type: {{finding.expected.waiver_type || 'N/A'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "size": "sm",
                          "children": "Waiver status: {{finding.expected.waiver_status || 'Unknown'}} · Recommended: {{finding.proposed_action}}"
                        }
                      },
                      {
                        "type": "Text",
                        "if": "{{finding.expected.stale_inputs && finding.expected.stale_inputs.length > 0}}",
                        "props": {
                          "size": "sm",
                          "variant": "muted",
                          "children": "Uncertainty: {{finding.expected.stale_inputs[0]}}"
                        }
                      },
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "justify": "between", "align": "center" },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "size": "sm",
                              "variant": "muted",
                              "children": "{{finding.rationale || 'No rationale provided.'}}"
                            }
                          },
                          {
                            "type": "Link",
                            "props": {
                              "to": "/ops/findings/{{finding.id}}",
                              "search": {
                                "source": "lien-deadlines",
                                "returnStatus": "{{state.waiverStatusFilter}}"
                              },
                              "children": "Open finding"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
