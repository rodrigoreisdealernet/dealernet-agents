{
  "id": "shop-morning-queue",
  "title": "Shop Morning Queue",
  "state": {
    "priorityFilter": "%",
    "itemTypeFilter": "%",
    "statusFilter": "pending_approval",
    "staleOnly": false
  },
  "dataSources": {
    "queueItems": {
      "type": "supabase",
      "table": "ops_findings_view",
      "select": "id, agent_key, finding_type, severity, status, contract_id, evidence, proposed_action, rationale, confidence, is_stale, created_at, expected",
      "filters": [
        { "field": "agent_key", "op": "eq", "value": "shop-morning-queue" },
        { "field": "severity", "op": "ilike", "value": "{{state.priorityFilter || '%'}}" },
        { "field": "finding_type", "op": "ilike", "value": "{{state.itemTypeFilter || '%'}}" },
        { "field": "status", "op": "ilike", "value": "{{state.statusFilter || '%'}}" }
      ],
      "order": [
        { "column": "created_at", "ascending": false }
      ],
      "refetchInterval": 30000
    },
    "assets": {
      "type": "supabase",
      "table": "entities",
      "select": "id, entity_versions!inner(data, is_current)",
      "filters": [
        { "field": "entity_type", "op": "eq", "value": "asset" },
        { "field": "entity_versions.is_current", "op": "eq", "value": true }
      ]
    },
    "latestRun": {
      "type": "supabase",
      "table": "ops_workflow_run",
      "select": "run_id, workflow_key, status, started_at, finished_at",
      "filters": [
        { "field": "workflow_key", "op": "eq", "value": "shop-morning-queue" }
      ],
      "order": [{ "column": "started_at", "ascending": false }],
      "limit": 1,
      "single": true
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "spacing": 1 },
        "children": [
          { "type": "Heading", "props": { "level": 1, "children": "Shop Morning Queue" } },
          {
            "type": "Text",
            "props": {
              "variant": "muted",
              "children": "Disposition-ready morning queue for the service & maintenance manager: PM-due units, open work-order priorities, parts blockers, and not-available equipment."
            }
          }
        ]
      },
      {
        "type": "Alert",
        "if": "{{data.latestRun && data.latestRun.status === 'no_op'}}",
        "props": {
          "variant": "info",
          "title": "No new shop signals",
          "description": "The last queue run found no materially new PM-due units, open work orders, or not-available equipment. Review the queue manually if you believe a new signal has appeared since the last run."
        }
      },
      {
        "type": "Grid",
        "props": { "columns": "repeat(auto-fit, minmax(12rem, 1fr))", "gap": 3 },
        "children": [
          {
            "type": "Select",
            "props": {
              "label": "Priority",
              "value": "{{state.priorityFilter}}",
              "options": [
                { "value": "%", "label": "All" },
                { "value": "critical", "label": "Critical" },
                { "value": "high", "label": "High" },
                { "value": "medium", "label": "Medium" },
                { "value": "low", "label": "Low" }
              ],
              "onChange": {
                "action": "setState",
                "key": "priorityFilter",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Select",
            "props": {
              "label": "Queue Type",
              "value": "{{state.itemTypeFilter}}",
              "options": [
                { "value": "%", "label": "All" },
                { "value": "pm_due", "label": "PM Due (t1)" },
                { "value": "work_order_priority", "label": "Work Order Priority (t2)" },
                { "value": "not_available_unit", "label": "Not Available (t3)" },
                { "value": "parts_blocker", "label": "Parts Blocker (t6)" }
              ],
              "onChange": {
                "action": "setState",
                "key": "itemTypeFilter",
                "value": "{{event.target.value}}"
              }
            }
          },
          {
            "type": "Select",
            "props": {
              "label": "Status",
              "value": "{{state.statusFilter}}",
              "options": [
                { "value": "%", "label": "All" },
                { "value": "pending_approval", "label": "Pending Review" },
                { "value": "approved", "label": "Actioned" },
                { "value": "rejected", "label": "Deferred" },
                { "value": "informational", "label": "Informational" }
              ],
              "onChange": {
                "action": "setState",
                "key": "statusFilter",
                "value": "{{event.target.value}}"
              }
            }
          }
        ]
      },
      {
        "type": "Text",
        "if": "{{isLoading.queueItems}}",
        "props": { "variant": "muted", "children": "Loading morning queue..." }
      },
      {
        "type": "Alert",
        "if": "{{errors.queueItems}}",
        "props": {
          "variant": "destructive",
          "title": "Unable to load morning queue",
          "description": "Check filters or retry shortly."
        }
      },
      {
        "type": "Text",
        "if": "{{!isLoading.queueItems && !errors.queueItems && data.queueItems && data.queueItems.length === 0}}",
        "props": {
          "variant": "muted",
          "children": "No queue items match the current filters."
        }
      },
      {
        "type": "Stack",
        "if": "{{!isLoading.queueItems && !errors.queueItems && data.queueItems && data.queueItems.length > 0}}",
        "props": { "spacing": 3 },
        "children": [
          {
            "type": "List",
            "props": {
              "items": "{{data.queueItems}}",
              "keyField": "id",
              "renderItem": {
                "type": "Card",
                "props": { "padding": 4 },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "spacing": 2 },
                    "children": [
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
                        "children": [
                          {
                            "type": "Badge",
                            "props": {
                              "status": "{{item.severity}}",
                              "children": "{{item.severity}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "props": {
                              "variant": "outline",
                              "children": "{{formatFindingType(item.finding_type)}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "props": {
                              "status": "{{item.status}}",
                              "children": "{{formatFindingStatus(item.status)}}"
                            }
                          },
                          {
                            "type": "Badge",
                            "if": "{{item.expected && item.expected.is_stale_data}}",
                            "props": {
                              "variant": "warning",
                              "children": "Stale data"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "props": {
                          "weight": "semibold",
                          "children": "{{lookupEntityFieldById(data.assets, item.contract_id, 'name', 'identifier') || '—'}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "variant": "muted",
                          "children": "{{item.proposed_action || item.rationale || '—'}}"
                        }
                      },
                      {
                        "type": "Stack",
                        "if": "{{item.evidence && item.evidence.length > 0}}",
                        "props": { "spacing": 1 },
                        "children": [
                          {
                            "type": "Text",
                            "props": { "size": "sm", "weight": "medium", "children": "Evidence" }
                          },
                          {
                            "type": "List",
                            "props": {
                              "items": "{{item.evidence}}",
                              "renderItem": {
                                "type": "Text",
                                "props": { "size": "sm", "variant": "muted", "children": "{{item}}" }
                              }
                            }
                          }
                        ]
                      },
                      {
                        "type": "Stack",
                        "if": "{{item.expected && item.expected.stale_signals && item.expected.stale_signals.length > 0}}",
                        "props": { "spacing": 1 },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "size": "sm",
                              "weight": "medium",
                              "variant": "warning",
                              "children": "Stale signals — review before acting"
                            }
                          },
                          {
                            "type": "List",
                            "props": {
                              "items": "{{item.expected.stale_signals}}",
                              "renderItem": {
                                "type": "Text",
                                "props": { "size": "sm", "variant": "warning", "children": "{{item}}" }
                              }
                            }
                          }
                        ]
                      },
                      {
                        "type": "Stack",
                        "if": "{{item.expected && item.expected.blockers && item.expected.blockers.length > 0}}",
                        "props": { "spacing": 1 },
                        "children": [
                          {
                            "type": "Text",
                            "props": { "size": "sm", "weight": "medium", "children": "Blockers" }
                          },
                          {
                            "type": "List",
                            "props": {
                              "items": "{{item.expected.blockers}}",
                              "renderItem": {
                                "type": "Text",
                                "props": { "size": "sm", "variant": "muted", "children": "{{item}}" }
                              }
                            }
                          }
                        ]
                      },
                      {
                        "type": "Stack",
                        "if": "{{item.expected && item.expected.return_to_fleet_eta}}",
                        "props": { "spacing": 1 },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "size": "sm",
                              "children": "Estimated return to fleet: {{item.expected.return_to_fleet_eta}} — requires manager approval before branch communication."
                            }
                          }
                        ]
                      },
                      {
                        "type": "Stack",
                        "props": { "direction": "horizontal", "spacing": 2 },
                        "children": [
                          {
                            "type": "Link",
                            "if": "{{item.contract_id}}",
                            "props": {
                              "href": "/entities/asset/{{item.contract_id}}",
                              "children": "View Asset →"
                            }
                          },
                          {
                            "type": "Link",
                            "props": {
                              "href": "/ops/findings/{{item.id}}",
                              "children": "View Detail →"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          }
        ]
      }
    ]
  }
}
