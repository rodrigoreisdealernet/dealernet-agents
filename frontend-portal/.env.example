# Copie para .env e ajuste conforme o ambiente.

# Backend GeneXus (DealernetHubIntegration, .NET Core) — host:porta.
VITE_API_TARGET=http://localhost:8082

# Base das APIs do portal (inclui o nome da app GeneXus + /api/v1/portal).
VITE_API_BASE=/DealernetHubIntegrationNETCoreSQL/api/v1/portal

# Liga as APIs reais (true) ou usa mocks locais (false, default).
VITE_USE_REAL_API=false

# Supabase (Operations Factory / dealernet-agents) — EXIGIDO por
# src/portal/lib/agentsApi.ts. O createClient() roda no topo do módulo e estoura
# com "supabaseKey is required." se a anon key for vazia — e a app NÃO monta
# (tela branca, sem erro de React no console). Mantenha um valor não-vazio.
# Para dados reais, use a anon key padrão do Supabase CLI local.
VITE_SUPABASE_URL=http://127.0.0.1:54331
VITE_SUPABASE_ANON_KEY=dev-anon-key
