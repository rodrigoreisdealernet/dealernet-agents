# Supabase
SUPABASE_URL=http://localhost:55432
SUPABASE_ANON_KEY=dev-anon-key
SUPABASE_SERVICE_ROLE_KEY=dev-service-role-key
SUPABASE_DB_USER=supabase
SUPABASE_DB_PASSWORD=supabase
SUPABASE_DB_NAME=supabase

# Temporal
# When running the worker inside Docker Compose, use the service name: temporal:7233
# When running the worker on the host (outside Docker), use: localhost:7234
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=main

# Frontend
VITE_SUPABASE_URL=http://localhost:55432
VITE_SUPABASE_ANON_KEY=dev-anon-key
VITE_API_URL=http://localhost:55432/functions/v1
