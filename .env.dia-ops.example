# Example env for the isolated Dealernet ops stack (docker-compose.dia-ops.yml).
# Copy to .env.dia-ops and fill with real, LOCAL-ONLY secrets. Never commit the real file.

# Supabase service-role key — standard Supabase CLI local demo key (from `supabase status`).
SUPABASE_SERVICE_ROLE_KEY=<supabase-local-service-role-key>

# Azure OpenAI — used by the Temporal worker / ops agents.
# AZURE_OPENAI_ENDPOINT is the resource BASE url; the client appends
#   /openai/deployments/<deployment>/chat/completions?api-version=<version>
# NOTE: if the resource only serves the Responses API (/openai/responses), the
# agent transport must be adapted accordingly (see issue #32).
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=<azure-openai-api-key>
AZURE_OPENAI_DEPLOYMENT=<deployment-name>
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Optional failover deployment.
# AZURE_OPENAI_SECONDARY_ENDPOINT=https://<your-secondary>.cognitiveservices.azure.com
# AZURE_OPENAI_SECONDARY_API_KEY=<azure-openai-secondary-api-key>
# AZURE_OPENAI_SECONDARY_DEPLOYMENT=<secondary-deployment-name>
# AZURE_OPENAI_SECONDARY_API_VERSION=2025-04-01-preview
